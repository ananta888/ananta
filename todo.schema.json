{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/todo.schema.json",
  "title": "Ananta Todo Schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "created",
    "updated",
    "project",
    "review_basis",
    "categories",
    "meta"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "minLength": 1
    },
    "updated": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "review_basis": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "reviewed_commit_range",
        "review_goal"
      ],
      "properties": {
        "reviewed_commit_range": {
          "type": "string",
          "minLength": 1
        },
        "review_goal": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "total_items",
        "by_status",
        "notes",
        "recommended_order"
      ],
      "properties": {
        "total_items": {
          "type": "integer",
          "minimum": 0
        },
        "by_status": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "completed",
            "partial",
            "open"
          ],
          "properties": {
            "completed": {
              "type": "integer",
              "minimum": 0
            },
            "partial": {
              "type": "integer",
              "minimum": 0
            },
            "open": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "label",
        "items"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/todoItem"
          }
        }
      }
    },
    "todoItem": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "description",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "$ref": "#/$defs/flexiblePriority"
        },
        "type": {
          "$ref": "#/$defs/flexibleNamedString"
        },
        "principle": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/flexibleStatus"
        },
        "effort": {
          "$ref": "#/$defs/flexibleEffort"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "context": {
          "$ref": "#/$defs/freeformObject"
        },
        "metadata": {
          "$ref": "#/$defs/freeformObject"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "decision_log": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decisionLogEntry"
          }
        },
        "subtasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subtask"
          }
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "flexibleNamedString": {
      "type": "string",
      "minLength": 1
    },
    "flexiblePriority": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "flexibleStatus": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "open",
            "partial",
            "completed",
            "done",
            "in_progress",
            "blocked",
            "planned"
          ]
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "flexibleEffort": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "tiny",
            "small",
            "medium",
            "large",
            "xlarge",
            "xxlarge"
          ]
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "freeformValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/freeformValue"
          }
        },
        {
          "$ref": "#/$defs/freeformObject"
        }
      ]
    },
    "freeformObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/freeformValue"
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "target"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "decisionLogEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subtask": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/flexibleStatus"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
