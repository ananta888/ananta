%% Ananta architecture - simple explanation for demos
%% Die Pfeile sind bewusst als Satz lesbar.
%% Beispiel: Hub delegiert Aufgaben an Worker.

flowchart TD
    U["User / UI / CLI"] -->|"gibt Auftrag an"| H["Hub\nKoordinator"]

    H -->|"delegiert Aufgabe an"| W1["Worker 1"]
    H -->|"delegiert Aufgabe an"| W2["Worker 2"]
    H -->|"delegiert Aufgabe an"| W3["Worker 3"]

    W1 -->|"beinhaltet"| A1["Agent / Tool\nz.B. OpenCode"]
    W2 -->|"beinhaltet"| A2["Agent / Tool\nz.B. Hermes"]
    W3 -->|"beinhaltet"| A3["Agent / Tool\nz.B. Ananta-Worker"]

    H -->|"fragt Kontext an"| CC["CodeCompass\nContextManager"]
    CC -->|"liefert Kontext an"| H
    CC -->|"liest und indexiert"| SRC["Projektcode\nDateien · Symbole · Artefakte · RAG"]

    A1 -->|"liefert Ergebnis an"| H
    A2 -->|"liefert Ergebnis an"| H
    A3 -->|"liefert Ergebnis an"| H

    H -.->|"erzwingt Standardpfad"| RULE["User -> Hub -> Worker -> Agent/Tool\nkein Agent->Agent\nkein Worker->Worker"]
