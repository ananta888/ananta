{
  "listen": {
    "host": "127.0.0.1",
    "port": 8787,
    "prefix": "/v1"
  },
  "upstreams": [
    {
      "id": "local-lmstudio",
      "type": "openai_compatible",
      "base_url": "http://127.0.0.1:1234/v1",
      "api_key_env": null,
      "trust_level": "local",
      "allowed_models": [
        "intercepted-coder",
        "qwen2.5-coder:14b"
      ],
      "timeout_seconds": 60
    },
    {
      "id": "openrouter",
      "type": "openrouter_compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "trust_level": "cloud",
      "allowed_models": [
        "openai/gpt-4.1-mini"
      ],
      "timeout_seconds": 60
    }
  ],
  "routing": {
    "default_upstream": "local-lmstudio",
    "default_model": "intercepted-coder",
    "rules": [
      {
        "when": {
          "worker": "opencode",
          "task_kind": "coding",
          "risk_lte": "medium"
        },
        "upstream": "local-lmstudio",
        "model": "intercepted-coder"
      },
      {
        "when": {
          "requires_cloud": true,
          "context_class": "public_or_redacted"
        },
        "upstream": "openrouter",
        "model": "openai/gpt-4.1-mini"
      }
    ]
  },
  "policy": {
    "default_action": "deny_if_unclassified",
    "default_deny_secrets": true,
    "cloud_context_default": "redacted_minimal",
    "local_context_default": "allowed_by_context_gate",
    "allow_worker_override_upstream": false,
    "allow_prompt_override_policy": false,
    "max_context_chars_default": 120000
  },
  "redaction": {
    "enabled": true,
    "block_private_keys": true,
    "block_env_files": true,
    "patterns": [
      "api[_-]?key",
      "secret",
      "token",
      "password",
      "BEGIN OPENSSH PRIVATE KEY",
      "BEGIN RSA PRIVATE KEY"
    ]
  },
  "response_validation": {
    "validate_openai_shape": true,
    "validate_stream_chunks": true,
    "structured_json_repair_attempts": 1
  }
}

