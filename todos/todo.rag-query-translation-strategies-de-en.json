      "acceptance_criteria": [
        "Eine deutsche Query erzeugt mindestens eine englische/code-nahe Suchvariante.",
        "Beispiel: 'Wie funktioniert der Autopilot-Tick-Engine?' erzeugt 'autopilot tick engine process tasks' oder eine vergleichbar code-nahe Variante.",
        "Deutsche Verben wie funktioniert, verarbeitet, erstellt, lädt, speichert, startet, stoppt, plant und delegiert werden auf sinnvolle englische Code-Tokens gemappt.",
        "Deutsche Substantive wie Aufgabe, Aufgaben, Datei, Dateien, Konfiguration, Quelle, Artefakt, Berechtigung und Benutzer werden auf englische Retrieval-Tokens gemappt.",
        "Code-Tokens wie snake_chat, RepositoryMapEngine, autopilot_tick_engine.py, task_id und camelCase bleiben erhalten und werden nicht kaputtübersetzt.",
        "Bindestriche, Unterstriche, CamelCase und Dateiendungen werden tokenisiert, ohne die Originalform zu verlieren."
      ],
      "test_expectations": [
        "Unit-Test prüft Autopilot-Tick-Engine Beispiel.",
        "Unit-Test prüft deutsche Verben und Substantive.",
        "Unit-Test prüft Erhalt von snake_case, CamelCase und Dateinamen.",
        "Unit-Test prüft, dass kein LLM-/Netzwerkzugriff im Keyword-/Glossary-Modus passiert."
      ]
    },
