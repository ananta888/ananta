  "track": "rag-query-translation-strategies-de-en",
  "purpose": "Ergänzung zu todo.rag-config-layer-quotas-exclusions-query-normalization.json: Query-Übersetzung und bidirektionale Sprachstrategien DE↔EN für RAG, RepositoryMap und Snake-/Chat-Kontext sauber definieren.",
  "goal": "Deutschsprachige Nutzerfragen sollen englische Code-Symbole, Dateinamen und Doku zuverlässig finden; englische Queries sollen optional deutschsprachige Doku, Kommentare oder Artefakte finden. Originalquery bleibt immer erhalten, Übersetzung ist nur Expansion, kein Ersatz.",
  "related_track": "todos/todo.rag-config-layer-quotas-exclusions-query-normalization.json",
  "status_scale": ["todo", "in_progress", "partial", "blocked", "done"],
  "priority_scale": ["P0", "P1", "P2", "P3"],
  "risk_scale": ["low", "medium", "high"],
  "translation_strategy_contract": {
    "principles": [
      "Originalquery darf niemals verworfen werden.",
      "Übersetzung erzeugt zusätzliche Suchvarianten für Retrieval.",
      "Default muss lokal/offline ohne LLM funktionieren.",
      "LLM-Übersetzung ist optional und muss timeout-/fallback-sicher sein.",
      "Keine Secrets, Artefakte oder langen Projektkontexte an einen Übersetzungs-LLM senden.",
      "Strategien müssen deduplizierbar und testbar sein."
    ],
    "directions": [
      "de_to_en",
      "en_to_de",
      "mixed_code_query",
      "no_translation"
    ],
    "modes": [
      "off",
      "keyword",
      "glossary",
      "llm"
    ],
    "default_mode": "keyword",
    "default_langs": "de,en"
  },
  "milestones": [
    {
      "id": "RTS-1",
      "title": "Sprachstrategie und Konfigurationsvertrag definieren",
      "task_ids": ["RTS-001", "RTS-002"],
      "status": "todo"
    },
    {
      "id": "RTS-2",
      "title": "DE↔EN Query Expansion implementieren",
      "task_ids": ["RTS-003", "RTS-004", "RTS-005"],
      "status": "todo"
    },
    {
      "id": "RTS-3",
      "title": "Retrieval-Integration, Ranking und Tests absichern",
