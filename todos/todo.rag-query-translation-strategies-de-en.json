    {
      "id": "RTS-003",
      "title": "DE→EN Keyword-/Glossary-Expansion für Code-Retrieval umsetzen",
      "type": "backend-feature",
      "milestone": "RTS-2",
      "status": "todo",
      "priority": "P0",
      "risk": "high",
      "progress_percent": 0,
