      "test_expectations": [
        "Unit-Test prüft permission/user/update/field Beispiel.",
        "Unit-Test prüft, dass englische Code-Tokens erhalten bleiben.",
        "Unit-Test prüft, dass EN→DE deaktivierbar ist."
      ]
    },
