      "acceptance_criteria": [
        "Doku beschreibt DE→EN für deutschsprachige Userqueries auf englische Code-Symbole und Dateinamen.",
        "Doku beschreibt EN→DE für englische Userqueries auf deutschsprachige Doku, Kommentare, Aufgaben und Artefakte.",
        "Doku beschreibt mixed_code_query: deutsch/englisch gemischte Queries mit Code-Tokens, z.B. 'wie läuft task processing im autopilot_tick_engine'.",
        "Doku stellt klar: Originalquery bleibt immer erhalten; Übersetzung ist zusätzliche Retrieval-Expansion.",
        "Doku stellt klar: Query-Translation ist nicht dasselbe wie Antwortübersetzung.",
        "Doku nennt Grenzen: Keyword-/Glossary-Strategien sind bewusst grob und dürfen keine fachliche Semantik erfinden."
      ],
      "test_expectations": [
        "Docs-Review prüft, dass DE→EN und EN→DE beide explizit erwähnt sind.",
        "Docs-Review prüft, dass Originalquery-never-drop als Muss-Regel enthalten ist."
      ]
    },
