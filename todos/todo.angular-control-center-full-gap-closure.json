  "track": "todo.angular-control-center-full-gap-closure",
  "title": "Control Center: vollständige Gap-Closure (Frontend + Backend)",
  "purpose": "Alle verbleibenden Lücken für ein produktionsreifes, sicheres Ananta Control Center schließen.",
  "goal": "Ein durchgängig funktionsfähiges Control Center, das Task-/Session-/Policy-/Artifact-/Verification-Flows live, nachvollziehbar und backend-autoritativ abbildet.",
  "status": "in_progress",
  "status_scale": [
    "todo",
    "in_progress",
    "partial",
    "blocked",
    "done"
  ],
  "priority_scale": [
    "critical",
