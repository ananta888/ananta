    "medium",
    "low"
  ],
  "risk_scale": [
    "low",
    "medium",
    "high",
    "critical"
  ],
  "architecture_guards": {
    "must_hold": [
      "Hub bleibt zentrale Control Plane",
      "Keine Worker-zu-Worker-Orchestrierung",
      "UI ist nie Security-Source-of-Truth",
      "Policy-/Approval-Entscheidungen ausschließlich backendseitig"
    ]
  },
  "baseline": {
    "already_present": [
      "Control-Center-Frontend-MVP-Routen und Shell",
      "Task/Session/Policy/Artifact-Komponenten als UI-Stub/MVP",
      "SSE-Client mit Reconnect im Frontend",
      "Artifact- und Teile von Task-/Orchestration-Backend bereits vorhanden"
    ],
    "core_gap": "Einheitliche, belastbare Backend-Read-Model- und Action-Endpoints fehlen oder sind nur indirekt/adapterbasiert nutzbar."
  },
