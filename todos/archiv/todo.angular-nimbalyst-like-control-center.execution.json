  "scope_policy": {
    "mvp_included": [
      "3-Spalten-Shell (Navigation, Workspace, Inspector)",
      "Task-Board mit Statusspalten und Risiko-Chips",
      "Session-Detail mit Tool-Call-Timeline",
      "Security-Inspector (Worker/Modell/Runtime/Policy-Snapshot)",
      "Artefakt-Browser + Viewer (Markdown, Diff, JSON, Logs)",
      "Policy-Decision-Log + enger Approval-Flow",
      "Live-Updates via SSE (mit Reconnect)",
      "Verification-Panel als Abschlusskriterium"
    ],
    "mvp_excluded": [
      "Komplette Worktree-/Branch-Orchestrierung im UI",
      "Unkontrollierte Terminal-Ausführung",
      "UI-seitige Security-Entscheidungen"
    ]
  },
