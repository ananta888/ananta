{
  "version": "1.1",
  "default_profile": "local",
  "profiles": [
    {
      "profile_id": "public-ananta",
      "label": "Public Ananta Test Rendezvous",
      "description": "Öffentliche, stark begrenzte Ananta-Testinfrastruktur: keycloak.ananta.de für OIDC und webrtc.ananta.de für Rendezvous/Signaling/STUN/TURN. Von Peter Stuiber/ananta.de kostenlos zum Testen bereitgestellt. Nicht für Produktion, vertrauliche Daten oder SLA-pflichtige Nutzung.",
      "enabled_by_default": false,
      "requires_explicit_opt_in": true,
      "public_rendezvous": true,
      "warning": "Dieses Profil nutzt öffentliche Ananta-Testserver. Routing-/Session-Metadaten sind für den Betreiber sichtbar. Inhalte müssen E2E-verschlüsselt werden. Nutzung nur begrenzt und experimentell.",
      "oidc": {
        "issuer": "https://keycloak.ananta.de/realms/ananta",
        "client_id": "ananta-tui",
        "audience": "ananta-hub",
        "pkce_required": true
      },
      "rendezvous": {
        "base_url": "https://webrtc.ananta.de",
        "signaling_url": "wss://webrtc.ananta.de/signaling",
        "transport_order": ["webrtc", "hub_relay"],
        "require_e2e_payload_encryption": true
      },
      "ice_servers": [
        {
          "urls": ["stun:webrtc.ananta.de:3478"]
        },
        {
          "urls": ["turn:webrtc.ananta.de:3478"],
          "credential_mode": "ephemeral_from_rendezvous_or_test_env"
        }
      ],
      "turn": {
        "urls": ["turn:webrtc.ananta.de:3478"],
        "test_url": "turn:webrtc.ananta.de:3478",
        "experimental_tls_urls": ["turns:webrtc.ananta.de:5349"],
        "credential_mode": "ephemeral_from_rendezvous_or_test_env",
        "relay_port_range": "49160-49200/udp"
      },
      "limits": {
        "intended_use": "testing_only",
        "free_public_service": true,
        "service_level_agreement": false,
        "max_session_duration_minutes_default": 60,
        "remote_control_default": false,
        "view_share_default": false,
        "notes_share_default": false
      }
    },
    {
      "profile_id": "local",
      "label": "Local / Private Deployment",
      "description": "Eigene lokale oder private Ananta-Infrastruktur. Endpunkte werden per ENV oder config.json konfiguriert.",
      "enabled_by_default": true,
      "public_rendezvous": false,
      "oidc": {
        "issuer": "",
        "client_id": "ananta-tui",
        "audience": "ananta-hub",
        "pkce_required": true
      },
      "rendezvous": {
        "base_url": "",
        "signaling_url": "",
        "transport_order": ["hub_relay"],
        "require_e2e_payload_encryption": false
      },
      "turn": {
        "urls": [],
        "credential_mode": "none"
      }
    },
    {
      "profile_id": "offline",
      "label": "Offline / No Network",
      "description": "Keine Netzwerkverbindung. Chat, View-Share und OIDC sind deaktiviert.",
      "enabled_by_default": false,
      "public_rendezvous": false,
      "oidc": {
        "issuer": "",
        "client_id": "",
        "audience": "",
        "pkce_required": false
      },
      "rendezvous": {
        "base_url": "",
        "signaling_url": "",
