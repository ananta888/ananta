      "enabled_by_default": false,
      "public_rendezvous": false,
      "oidc": {
        "issuer": "",
        "client_id": "",
        "audience": "",
        "pkce_required": true
      },
      "rendezvous": {
        "base_url": "",
        "signaling_url": "",
        "transport_order": ["webrtc", "hub_relay"],
        "require_e2e_payload_encryption": true
