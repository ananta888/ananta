      "profile_id": "public-ananta",
      "label": "Public Ananta Rendezvous",
      "description": "Öffentliche Ananta-Infrastruktur: keycloak.ananta.de (OIDC) und webrtc.ananta.de (Rendezvous/Signaling). Inhalte werden E2E-verschlüsselt, Routing-Metadaten sind für die Server sichtbar.",
      "enabled_by_default": false,
      "oidc": {
        "issuer": "https://keycloak.ananta.de/realms/ananta",
        "client_id": "ananta-tui",
        "audience": "ananta-hub",
        "pkce_required": true
      },
      "rendezvous": {
        "base_url": "https://webrtc.ananta.de",
        "signaling_url": "wss://webrtc.ananta.de/signaling",
        "transport_order": ["webrtc", "hub_relay"],
        "require_e2e_payload_encryption": true
      },
      "turn": {
        "urls": ["turns:webrtc.ananta.de:5349"],
        "credential_mode": "ephemeral_from_rendezvous"
      }
    },
