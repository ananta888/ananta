# ─────────────────────────────────────────────────────────────────────────────
# LOCAL LLM RUN CONFIGURATION
# Diese Datei einmal pro Rechner/Setup anpassen, dann run_3er_lauf_lokal.sh
# aufrufen – keine anderen Dateien müssen verändert werden.
# ─────────────────────────────────────────────────────────────────────────────

# Provider: ollama | lmstudio
LOCAL_PROVIDER=lmstudio

# Base-URL des lokalen LLM-Providers
#
#   LMStudio (Netzwerk):       http://192.168.178.100:1234
#   LMStudio (localhost):      http://localhost:1234
#   Ollama (Docker-intern):    http://ollama:11434
#   Ollama (host localhost):   http://localhost:11434
#
LOCAL_URL=http://192.168.178.100:1234

# Modellname
#   "auto"                  → LMStudio wählt das geladene Modell selbst
#   "ananta-default:latest" → Standard-Tag für Ollama-Modelle
#   "qwen2.5-coder:14b"    → Beispiel expliziter Ollama-Modellname
#
LOCAL_MODEL=auto

# ─── Ananta Hub ───────────────────────────────────────────────────────────────
ANANTA_BASE_URL=http://localhost:5000
ANANTA_USER=admin
# ANANTA_PASSWORD via Umgebungsvariable setzen, NICHT hier eintragen:
#   export ANANTA_PASSWORD='<passwort>'

# ─── Runner-Optionen (optional überschreiben) ─────────────────────────────────
# Config-Modus: goal_scoped | legacy_global_config
CONFIG_MODE=goal_scoped

# Maximale Laufzeit pro Run in Sekunden
SLA_SECONDS=900

# DB vor jedem Run zurücksetzen (1 = ja, 0 = nein)
# Sicherheitscheck: wird trotzdem nur für localhost akzeptiert
RESET_DB=0

# ─── Planning-Profil für lokale Modelle ───────────────────────────────────────
#   small   → englisches Prompt + 512 max_tokens + 400-Zeichen-Kontext (für kleine Modelle, z.B. gemma-4-e4b)
#   medium  → englisches Prompt + 768 max_tokens + 600-Zeichen-Kontext
#   (leer)  → Hub-Defaults (deutsches Prompt, 1024 max_tokens, kein Kontext-Limit)
PLANNING_PROFILE=small
