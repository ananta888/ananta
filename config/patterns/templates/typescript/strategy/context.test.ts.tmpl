import { describe, it, expect } from 'vitest';
import { @@context_class@@Context } from './context';
import { Primary@@context_class@@Strategy } from './primary.strategy';
import { Secondary@@context_class@@Strategy } from './secondary.strategy';

describe('@@context_class@@Context', () => {
  it('primary strategy sorts and lowercases', () => {
    const ctx = new @@context_class@@Context(new Primary@@context_class@@Strategy());
    expect(ctx.run({ items: ['B', 'a', 'c'] })).toEqual({
      variant: 'primary',
      items: ['a', 'b', 'c'],
    });
  });

  it('secondary strategy reverses the sort', () => {
    const ctx = new @@context_class@@Context(new Secondary@@context_class@@Strategy());
    expect(ctx.run({ items: ['B', 'a', 'c'] })).toEqual({
      variant: 'secondary',
      items: ['c', 'b', 'a'],
    });
  });

  it('strategy can be swapped at runtime', () => {
    const ctx = new @@context_class@@Context(new Primary@@context_class@@Strategy());
    ctx.setStrategy(new Secondary@@context_class@@Strategy());
    expect(ctx.run({ items: ['B', 'a', 'c'] })).toEqual({
      variant: 'secondary',
      items: ['c', 'b', 'a'],
    });
  });

  it('outputs are deterministic across calls', () => {
    const ctx = new @@context_class@@Context(new Primary@@context_class@@Strategy());
    const first = ctx.run({ items: ['X', 'y', 'Z'] });
    const second = ctx.run({ items: ['X', 'y', 'Z'] });
    expect(first).toEqual(second);
  });
});
