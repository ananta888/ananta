{
  "visual_viewport": {
    "enabled": false,
    "position": "center",
    "default_view": "renderer_diagnostics",
    "default_renderer": "cpu_raster",
    "default_output_adapter": "kitty",
    "target_fps": 10,
    "animation_fps": 15,
    "max_fps": 30,
    "default_pixel_width": 800,
    "default_pixel_height": 450,
    "max_pixel_width": 1280,
    "max_pixel_height": 720,
    "fallback_chain": [
      { "renderer": "cpu_raster", "adapter": "kitty" },
      { "renderer": "cpu_raster", "adapter": "sixel" },
      { "renderer": "ansi_blocks", "adapter": "ansi" }
    ]
  },
  "markdown_mermaid": {
    "markdown_mode": "ansi",
    "mermaid_mode": "auto",
    "mermaid_renderers": ["mermaid_cli", "playwright", "fallback_codeblock"],
    "timeout_seconds": 15.0,
    "max_diagram_width": 1280,
    "max_diagram_height": 720,
    "cache_enabled": true,
    "allowed_roots": []
  },
  "chat_control": {
    "mode": "interactive_safe",
    "enabled": true,
    "nl_mode_enabled": false,
    "confirmation_timeout_seconds": 30.0,
    "e2e_allowlist": [
      "help.tui", "view.list", "view.next", "view.previous", "view.select",
      "overlay.views.on", "overlay.views.off", "overlay.views.toggle",
      "focus.chat", "focus.artifacts",
      "snake.pause", "snake.resume", "snake.follow.on", "snake.follow.off"
    ]
  }
}
