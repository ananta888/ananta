{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/model_routing.schema.json",
  "title": "Ananta Model Routing Rules",
  "type": "object",
  "required": ["version", "routing_rules"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "_note": { "type": "string" },
    "security_policy": { "$ref": "#/$defs/SecurityPolicy" },
    "routing_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/RoutingRule" }
    },
    "fallback_chain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of profile_ids to try when no rule matches"
    },
    "fallback_groups": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/FallbackGroup" },
      "description": "Named ordered fallback chains"
    },
    "escalation_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/EscalationRule" }
    }
  },
  "$defs": {
    "SecurityPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "block_cloud_with_secrets": {
          "type": "boolean",
          "default": true,
          "description": "Block any cloud provider when secrets are detected in context"
        },
        "allowed_cloud_providers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Explicit whitelist of cloud provider_ids that may be used"
        },
        "secret_detection_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Regex patterns for detecting secrets in prompts"
        }
      }
    },
    "FallbackGroup": {
      "type": "object",
      "required": ["ordered_profiles"],
      "additionalProperties": true,
      "properties": {
        "ordered_profiles": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "max_total_retries": {
          "type": "integer",
          "minimum": 0
        },
        "stop_on_policy_block": {
          "type": "boolean",
          "default": true
        },
        "stop_on_success": {
          "type": "boolean",
          "default": true
        },
        "cost_policy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "max_input_price_per_million": { "type": "number", "minimum": 0 },
            "max_output_price_per_million": { "type": "number", "minimum": 0 },
            "max_estimated_cost_per_step": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "EscalationRule": {
      "type": "object",
      "required": ["trigger"],
      "additionalProperties": true,
      "properties": {
        "trigger": {
          "type": "string",
          "enum": [
            "provider_unavailable",
            "timeout",
            "http_5xx",
            "http_4xx",
            "invalid_json_response",
            "empty_content",
            "schema_validation_failed",
            "tool_not_allowed",
            "tool_args_invalid",
            "repeated_tool_failure",
            "context_too_large",
            "policy_blocked"
          ]
        },
        "from_profile": { "type": ["string", "null"] },
        "to_profile": { "type": ["string", "null"] },
        "condition": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "min_context_tokens": { "type": "integer", "minimum": 0 },
            "task_kind": { "type": "string" },
            "step_kind": { "type": "string" },
            "model_role": { "type": "string" },
            "risk_class": { "type": "string" },
            "requires_json": { "type": "boolean" },
            "requires_tools": { "type": "boolean" },
            "previous_error_type": { "type": "string" },
            "repeated_failure_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "RoutingRule": {
      "type": "object",
      "required": ["rule_id", "profile_id"],
      "additionalProperties": true,
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_id": {
          "type": "string",
          "description": "Target profile_id from model_profiles config"
        },
        "model_role": {
          "type": "string",
          "description": "Apply when routing for this model role"
        },
        "blueprint_id": {
          "type": ["string", "null"],
          "description": "Apply only for this blueprint"
        },
        "task_kind": {
          "type": ["string", "null"],
          "description": "Apply only for this task kind"
        },
        "template_id": {
          "type": ["string", "null"],
          "description": "Apply only for this template"
        },
        "team_id": {
          "type": ["string", "null"],
          "description": "Apply only for this team"
        },
        "risk_class": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", "critical", null],
          "description": "Apply only for this risk classification"
        },
        "precedence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 11,
          "description": "Routing precedence rank (0=highest/security_policy, 11=legacy fallback)"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "reason": {
          "type": "string",
          "description": "Human-readable explanation why this rule exists"
        }
      }
    }
  }
}
