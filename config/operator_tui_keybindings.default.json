{
  "schema_version": "operator_tui_keybindings.v1",
  "bindings": [
    { "action": "command_mode", "key": "c-;", "display": "Ctrl+;", "label": "Command", "areas": ["footer-normal", "shortcuts"] },
    { "action": "toggle_snake_mode", "key": "c-s", "display": "Ctrl+S", "label": "Snake", "areas": ["footer-normal", "footer-snake", "shortcuts", "ai-panel"] },
    { "action": "toggle_chat_panel", "key": "c-g", "display": "Ctrl+G", "label": "AI-Chat", "areas": ["footer-normal", "footer-snake", "shortcuts", "ai-panel", "chat-panel"] },
    { "action": "chat_focus", "key": "c-e", "display": "Ctrl+E", "label": "Chat-Fokus", "areas": ["footer-normal", "footer-snake", "shortcuts", "ai-panel", "chat-panel"] },
    { "action": "copy_chat_panel", "key": "c-c", "display": "Ctrl+C", "label": "Chat kopieren", "areas": ["shortcuts", "chat-panel"] },
    { "action": "copy_ai_status", "key": "c-i", "display": "Ctrl+I", "label": "AI-Status kopieren", "areas": ["shortcuts", "ai-panel"] },
    { "action": "copy_tui_snapshot", "key": "c-\\", "display": "Ctrl+\\", "label": "TUI Snapshot kopieren", "areas": ["footer-normal", "footer-snake", "shortcuts"] },
    { "action": "save_tui_snapshot", "key": "c-_", "display": "Ctrl+_", "label": "TUI Snapshot speichern", "areas": ["footer-normal", "footer-snake", "shortcuts"] },
    { "action": "clear_chat_input", "key": "c-l", "display": "Ctrl+L", "label": "Input leeren", "areas": ["footer-chat", "shortcuts", "chat-panel"] },
    { "action": "open_long_chat_message", "key": "c-space", "display": "Ctrl+Space", "label": "Lange Chatnachricht anzeigen", "areas": ["footer-chat", "footer-normal", "shortcuts", "chat-panel"] },
    { "action": "cycle_focus_or_channel", "key": "c-w", "display": "Ctrl+W", "label": "Fokus/Kanal", "areas": ["footer-normal", "footer-chat", "shortcuts", "chat-panel"] },
    { "action": "toggle_tutorial_ai", "key": "c-u", "display": "Ctrl+U", "label": "Auto-Heuristik", "areas": ["footer-snake", "shortcuts", "ai-panel"] },
    { "action": "toggle_mouse_follow", "key": "c-o", "display": "Ctrl+O", "label": "MouseFollow", "areas": ["footer-snake", "shortcuts"] },
    { "action": "snake_pause", "key": "c-p", "display": "Ctrl+P", "label": "Pause/Resume", "areas": ["footer-snake", "shortcuts"] },
    { "action": "snake_toggle_selection", "key": "c-x", "display": "Ctrl+X", "label": "Select/Mark", "areas": ["footer-snake", "shortcuts"] },
    { "action": "snake_toggle_frame", "key": "c-b", "display": "Ctrl+B", "label": "Frame", "areas": ["footer-snake", "shortcuts"] },
    { "action": "snake_replace_selection", "key": "c-v", "display": "Ctrl+V", "label": "Replace", "areas": ["footer-snake", "shortcuts"] },
    { "action": "snake_clear_marks", "key": "c-z", "display": "Ctrl+Z", "label": "Clear", "areas": ["footer-snake", "shortcuts"] },
    { "action": "send_terminal_context", "key": "c-t", "display": "Ctrl+T", "label": "Terminal→AI-Kontext", "areas": ["shortcuts"] },
    { "action": "toggle_shortcut_help", "key": "c-]", "display": "Ctrl+]", "label": "Shortcut-Hilfe", "areas": ["footer-normal", "shortcuts"] },
    { "action": "toggle_ai_snake_config", "key": "c-a", "display": "Ctrl+A", "label": "AI-Snake Config", "areas": ["footer-normal", "footer-snake", "footer-chat", "ai-panel", "chat-panel", "shortcuts"] },
    { "action": "selection_down", "key": "c-j", "display": "Ctrl+J", "label": "Selection runter", "areas": ["footer-normal", "shortcuts"] },
    { "action": "selection_up", "key": "c-k", "display": "Ctrl+K", "label": "Selection hoch", "areas": ["footer-normal", "shortcuts"] },
    { "action": "focus_left", "key": "c-1", "display": "Ctrl+1", "label": "Fokus links", "areas": ["footer-normal", "shortcuts"] },
    { "action": "focus_right", "key": "c-d", "display": "Ctrl+D", "label": "Fokus rechts", "areas": ["footer-normal", "shortcuts"] },
    { "action": "center_browser_toggle", "key": "c-2", "display": "Ctrl+2", "label": "Browser", "areas": ["footer-normal", "shortcuts"] },
    { "action": "switch_center_to_doc_view", "key": "c-3", "display": "Ctrl+3", "label": "Center→Doc", "areas": ["footer-normal", "shortcuts"] },
    { "action": "refresh", "key": "c-r", "display": "Ctrl+R", "label": "Refresh", "areas": ["footer-normal", "shortcuts"] },
    { "action": "help", "key": "c-y", "display": "Ctrl+Y", "label": "Help", "areas": ["footer-normal", "shortcuts"] },
    { "action": "inspect", "key": "c-f", "display": "Ctrl+F", "label": "Inspect/Open", "areas": ["footer-normal", "shortcuts"] },
    { "action": "next_section", "key": "c-n", "display": "Ctrl+N", "label": "Nächste Section", "areas": ["footer-normal", "shortcuts"] },
    { "action": "quit", "key": "c-q", "display": "Ctrl+Q", "label": "Quit", "areas": ["footer-normal", "shortcuts"] },
    { "action": "toggle_visual_view_switcher_overlay", "key": "c-4", "display": "Ctrl+4", "label": "View-Leiste", "areas": ["footer-normal", "footer-snake", "shortcuts"] },
    { "action": "next_visual_view", "key": "c-5", "display": "Ctrl+5", "label": "Nächste View", "areas": ["footer-normal", "shortcuts"] },
    { "action": "previous_visual_view", "key": "c-6", "display": "Ctrl+6", "label": "Vorherige View", "areas": ["footer-normal", "shortcuts"] },
    { "action": "scroll_page_up", "key": "c-7", "display": "Ctrl+7", "label": "Scroll hoch", "areas": ["footer-normal", "footer-snake", "shortcuts"] },
    { "action": "scroll_page_down", "key": "c-8", "display": "Ctrl+8", "label": "Scroll runter", "areas": ["footer-normal", "footer-snake", "shortcuts"] },
    { "action": "scroll_line_up", "key": "c-up", "display": "Ctrl+Up", "label": "Zeile hoch", "areas": ["shortcuts"] },
    { "action": "scroll_line_down", "key": "c-down", "display": "Ctrl+Down", "label": "Zeile runter", "areas": ["shortcuts"] },
    { "action": "scroll_home", "key": "c-home", "display": "Ctrl+Home", "label": "Scroll Anfang", "areas": ["shortcuts"] },
    { "action": "scroll_end", "key": "c-end", "display": "Ctrl+End", "label": "Scroll Ende", "areas": ["shortcuts"] },
    { "action": "scroll_left", "key": "c-left", "display": "Ctrl+←", "label": "Scroll links", "areas": ["footer-normal", "shortcuts"] },
    { "action": "scroll_right", "key": "c-right", "display": "Ctrl+→", "label": "Scroll rechts", "areas": ["footer-normal", "shortcuts"] },
    { "action": "scroll_left_page", "key": "c-pageup", "display": "Ctrl+PgUp", "label": "Scroll links (Seite)", "areas": ["shortcuts"] },
    { "action": "scroll_right_page", "key": "c-pagedown", "display": "Ctrl+PgDn", "label": "Scroll rechts (Seite)", "areas": ["shortcuts"] }
  ]
}
