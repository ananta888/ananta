{
  "name": "ananta-angular",
  "version": "0.7.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "ng serve --host 127.0.0.1 --port 4200",
    "start:e2e": "ng serve --host 127.0.0.1 --port 4200 --poll 2000 --prebundle=false",
    "stop:e2e": "node ./scripts/stop-e2e-frontend.js",
    "start:e2e:backend": "node ./scripts/start-e2e-backend.js",
    "stop:e2e:backend": "node ./scripts/stop-e2e-backend.js",
    "e2e:stack:up": "bash ../scripts/compose-test-stack.sh up",
    "e2e:stack:down": "bash ../scripts/compose-test-stack.sh down",
    "e2e:stack:clean": "bash ../scripts/compose-test-stack.sh clean",
    "e2e:stack:ps": "bash ../scripts/compose-test-stack.sh ps",
    "e2e:stack:up:cpu": "ANANTA_USE_WSL_VULKAN=0 bash ../scripts/compose-test-stack.sh up",
    "build": "ng build",
    "build:android": "ng build",
    "lint": "ng lint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:compose": "node ./scripts/run-e2e-compose.js",
    "test:e2e:lite": "node ./scripts/run-e2e-lite.js",
    "test:e2e:cleanup:selftest": "node ./scripts/e2e-cleanup-selftest.js",
    "test:e2e:cleanup:fix": "node ./scripts/e2e-cleanup-selftest.js --fix",
    "test:e2e:live": "node -e \"const {spawnSync}=require('node:child_process'); const extraArgs=process.argv.slice(1); const env={...process.env,RUN_LIVE_LLM_TESTS:'1',LIVE_LLM_PROVIDER:process.env.LIVE_LLM_PROVIDER||'ollama',OLLAMA_URL:process.env.OLLAMA_URL||'http://localhost:11434/api/generate'}; const args=extraArgs.length>0?extraArgs:['tests/templates-ai-live.spec.ts']; const r=spawnSync('npx',['playwright','test',...args],{stdio:'inherit',shell:true,env}); process.exit(r.status ?? 1);\"",
    "test:e2e:live:compose": "node ./scripts/run-e2e-live-compose.js",
    "test:e2e:live:reuse": "node ./scripts/run-e2e-live-reuse.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "npx cap sync android",
    "cap:copy": "npx cap copy android",
    "cap:open:android": "npx cap open android",
    "android:prepare": "npm run build:android && npm run cap:sync"
  },
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/forms": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-browser-dynamic": "^21.1.3",
    "@angular/router": "^21.1.3",
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.1.6",
    "marked": "^14.0.0",
    "mermaid": "^11.12.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.3",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cdk": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.3",
    "@axe-core/playwright": "^4.11.1",
    "@capacitor/cli": "^7.4.2",
    "@playwright/test": "^1.48.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "jsdom": "^26.1.0",
    "otplib": "^13.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zone.js": "^0.16.0"
  },
  "overrides": {
    "lodash-es": "4.17.23"
  }
}
