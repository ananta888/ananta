{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/integrations/workflow_descriptor.v1.json",
  "type": "object",
  "required": [
    "provider",
    "workflow_id",
    "display_name",
    "capability",
    "risk_class",
    "default_mode",
    "approval_required",
    "input_schema",
    "output_schema"
  ],
  "properties": {
    "provider": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string", "minLength": 1},
    "display_name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "workflow_ref": {"type": "string"},
    "trigger_url": {"type": "string"},
    "capability": {"type": "string", "enum": ["read", "write", "admin"]},
    "risk_class": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "default_mode": {"type": "string", "enum": ["disabled", "dry_run", "enabled"]},
    "approval_required": {"type": "boolean"},
    "dry_run_supported": {"type": "boolean"},
    "callback_required": {"type": "boolean"},
    "secret_refs": {"type": "array", "items": {"type": "string"}},
    "input_schema": {"type": "object"},
    "output_schema": {"type": "object"}
  },
  "additionalProperties": true
}
