{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.dev/schemas/sources/source_pack.v1.json",
  "title": "Source Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_pack_id",
    "display_name",
    "version",
    "sources",
    "codecompass_profiles",
    "bootstrap_steps",
    "license_policy"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "source_pack.v1"
    },
    "source_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "descriptor_path",
          "source_type",
          "trust_level",
          "fetch_source",
          "citation_source"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
          },
          "descriptor_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400
          },
          "source_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "trust_level": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "fetch_source": {
            "type": "object"
          },
          "citation_source": {
            "type": "object"
          },
          "source_priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000
          },
          "knowledge_domain": {
            "type": "string",
            "enum": [
              "source_code",
              "technical_docs",
              "general_knowledge",
              "plugin_development_knowledge"
            ]
          },
          "bootstrap_mode": {
            "type": "string",
            "enum": [
              "auto",
              "manual",
              "subset"
            ]
          },
          "abstraction_profile": {
            "type": "string",
            "enum": [
              "repo_code",
              "api_docs",
              "general_encyclopedia"
            ]
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "optional": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "retrieval_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "match_mode",
          "include_source_ids"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "match_mode": {
            "type": "string",
            "enum": [
              "technical_eclipse",
              "technical_keycloak",
              "general_fallback"
            ]
          },
          "include_source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
            }
          },
          "exclude_source_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
            }
          }
        }
      }
    },
    "codecompass_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "source_ids"
        ],
        "properties": {
          "profile_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
            }
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "query_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          }
        }
      }
    },
    "bootstrap_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "action"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "action": {
            "type": "string",
            "enum": [
              "download",
              "verify",
              "index",
              "validate"
            ]
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
            }
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "license_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_license_ref",
        "block_on_missing_license"
      ],
      "properties": {
        "require_license_ref": {
          "type": "boolean"
        },
        "block_on_missing_license": {
          "type": "boolean"
        },
        "allowed_licenses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    },
    "extensions": {
      "type": "object"
    }
  }
}
