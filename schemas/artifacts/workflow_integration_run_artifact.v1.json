{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/artifacts/workflow_integration_run_artifact.v1.json",
  "type": "object",
  "required": [
    "provider",
    "workflow_id",
    "correlation_id",
    "status",
    "mode",
    "timestamps",
    "provenance"
  ],
  "properties": {
    "provider": {"type": "string"},
    "workflow_id": {"type": "string"},
    "workflow_name": {"type": "string"},
    "correlation_id": {"type": "string"},
    "input_summary": {"type": "object"},
    "output_summary": {"type": "object"},
    "status": {"type": "string", "enum": ["queued", "started", "completed", "failed", "degraded", "blocked"]},
    "mode": {"type": "string", "enum": ["dry_run", "read", "write", "admin"]},
    "approval_ref": {"type": "string"},
    "external_run_ref": {"type": "string"},
    "timestamps": {"type": "object"},
    "provenance": {"type": "object"}
  },
  "additionalProperties": true
}
