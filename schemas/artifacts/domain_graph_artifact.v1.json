{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/artifacts/domain_graph_artifact.v1.json",
  "title": "Domain Graph Artifact v1",
  "type": "object",
  "required": [
    "schema",
    "source_kind",
    "source_ref",
    "nodes",
    "edges",
    "metadata"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "domain_graph_artifact.v1"
    },
    "source_kind": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "node_type"],
        "properties": {
          "node_id": {"type": "string", "minLength": 1},
          "node_type": {"type": "string", "minLength": 1},
          "attributes": {"type": "object", "additionalProperties": true}
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "target_id", "relation"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "target_id": {"type": "string", "minLength": 1},
          "relation": {"type": "string", "minLength": 1},
          "attributes": {"type": "object", "additionalProperties": true}
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false
}
