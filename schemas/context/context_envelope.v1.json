{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/context/context_envelope.v1.json",
  "title": "Ananta Context Envelope v1",
  "type": "object",
  "required": [
    "schema",
    "explicit_inputs",
    "retrieved_context",
    "source_refs",
    "redactions",
    "size_limits",
    "context_hash",
    "provenance"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "context_envelope.v1"
    },
    "explicit_inputs": {
      "type": "object",
      "required": [
        "user_selection",
        "client_captured"
      ],
      "properties": {
        "user_selection": {
          "type": "object",
          "required": [
            "text",
            "origin"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            },
            "origin": {
              "type": "string",
              "enum": [
                "editor_selection",
                "manual_input",
                "api_payload"
              ]
            },
            "language": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "client_captured": {
          "type": "object",
          "required": [
            "file_path",
            "project_root",
            "extra_paths",
            "rejected_paths"
          ],
          "properties": {
            "file_path": {
              "type": "string",
              "minLength": 1
            },
            "project_root": {
              "type": "string",
              "minLength": 1
            },
            "extra_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "rejected_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "retrieved_context": {
      "type": "object",
      "required": [
        "query",
        "chunks"
      ],
      "properties": {
        "query": {
          "type": "string"
        },
        "chunks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "chunk_id",
              "source_ref",
              "retrieval_reason",
              "content_excerpt"
            ],
            "properties": {
              "chunk_id": {
                "type": "string",
                "minLength": 1
              },
              "source_ref": {
                "type": "string",
                "minLength": 1
              },
              "retrieval_reason": {
                "type": "string",
                "minLength": 1
              },
              "content_excerpt": {
                "type": "string",
                "maxLength": 4000
              },
              "score": {
                "type": "number"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref_id",
          "kind",
          "location"
        ],
        "properties": {
          "ref_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "artifact",
              "knowledge_chunk",
              "repo_file",
              "url"
            ]
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "retrieval_reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "redactions": {
      "type": "object",
      "required": [
        "has_secret_redactions",
        "redaction_rules"
      ],
      "properties": {
        "has_secret_redactions": {
          "type": "boolean"
        },
        "redaction_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "size_limits": {
      "type": "object",
      "required": [
        "max_context_chars",
        "max_payload_bytes",
        "selection_clipped"
      ],
      "properties": {
        "max_context_chars": {
          "type": "integer",
          "minimum": 1
        },
        "max_payload_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "selection_clipped": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "context_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_by_component",
        "context_origin",
        "generated_at"
      ],
      "properties": {
        "created_by_component": {
          "type": "string",
          "enum": [
            "client",
            "hub",
            "worker"
          ]
        },
        "context_origin": {
          "type": "object",
          "required": [
            "has_user_input",
            "has_client_capture",
            "has_retrieval"
          ],
          "properties": {
            "has_user_input": {
              "type": "boolean"
            },
            "has_client_capture": {
              "type": "boolean"
            },
            "has_retrieval": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

