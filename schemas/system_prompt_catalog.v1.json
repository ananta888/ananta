{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/system_prompt_catalog.v1.json",
  "title": "System Prompt Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "prompts"],
  "properties": {
    "schema": { "type": "string", "const": "system_prompt_catalog.v1" },
    "version": { "type": "string", "minLength": 1 },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/prompt" }
    }
  },
  "$defs": {
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "description", "service", "prompt_template"],
      "properties": {
        "name":            { "type": "string", "minLength": 1, "pattern": "^system\\." },
        "label":           { "type": "string", "minLength": 1 },
        "description":     { "type": "string", "minLength": 1 },
        "service":         { "type": "string", "minLength": 1 },
        "variables":       { "type": "array", "items": { "type": "string" } },
        "prompt_template": { "type": "string", "minLength": 1 }
      }
    }
  }
}
