{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/worker/planner_proposal_artifact.v1.json",
  "title": "Ananta PlannerProposalArtifact v1",
  "description": "Non-executable planner output with sub-tasks. For task decomposition.",
  "type": "object",
  "required": ["schema", "proposal_id", "goal_id", "task_id", "strategy_id", "sub_tasks"],
  "properties": {
    "schema": { "type": "string", "const": "planner_proposal_artifact.v1" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "strategy_id": { "type": "string", "minLength": 1 },
    "sub_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "title", "description", "kind"],
        "properties": {
          "task_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "kind": { "type": "string" }
        }
      }
    },
    "reason": { "type": ["string", "null"] },
    "created_at": { "type": "number" },
    "metadata": { "type": "object", "default": {} }
  },
  "additionalProperties": false
}