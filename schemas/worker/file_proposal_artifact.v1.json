{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/worker/file_proposal_artifact.v1.json",
  "title": "Ananta FileProposalArtifact v1",
  "description": "Non-executable raw file proposal. Requires validation/approval before write.",
  "type": "object",
  "required": ["schema", "proposal_id", "goal_id", "task_id", "strategy_id", "files"],
  "properties": {
    "schema": { "type": "string", "const": "file_proposal_artifact.v1" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "strategy_id": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" },
          "mode": { "type": "string", "enum": ["create", "overwrite", "append"] }
        }
      }
    },
    "expected_artifacts": {
      "type": "array",
      "items": { "type": "object" },
      "default": []
    },
    "reason": { "type": ["string", "null"] },
    "created_at": { "type": "number" },
    "metadata": { "type": "object", "default": {} }
  },
  "additionalProperties": false
}