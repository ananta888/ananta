{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/worker/retrieval_index_contract.v1.json",
  "title": "Ananta Worker Retrieval Index Entry Contract v1",
  "type": "object",
  "required": [
    "schema",
    "chunk_id",
    "path",
    "text",
    "language",
    "start_byte",
    "end_byte",
    "source_hash",
    "embedding_version",
    "embedding"
  ],
  "properties": {
    "schema": { "type": "string", "const": "retrieval_index_entry.v1" },
    "chunk_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "text": { "type": "string" },
    "language": { "type": "string", "minLength": 1 },
    "symbol_name": { "type": "string" },
    "start_byte": { "type": "integer", "minimum": 0 },
    "end_byte": { "type": "integer", "minimum": 0 },
    "source_hash": { "type": "string", "minLength": 1 },
    "embedding_version": { "type": "string", "minLength": 1 },
    "embedding": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "number" }
    }
  },
  "additionalProperties": false
}

