{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillManifest",
  "description": "Versioned, capability-bound skill descriptor for the Ananta native worker. AWF-T027.",
  "type": "object",
  "required": ["id", "version", "name", "description", "required_capabilities", "allowed_tools", "denied_tools", "risk_class"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "required_capabilities": {
      "type": "array",
      "items": {"type": "string"}
    },
    "allowed_tools": {
      "type": "array",
      "items": {"type": "string"}
    },
    "denied_tools": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "context_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "approval_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tests": {
      "type": "array",
      "items": {"type": "string"}
    },
    "owner": {
      "type": "string"
    },
    "source": {
      "type": "string"
    }
  }
}
