{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/worker/worker_todo_contract.v1.json",
  "title": "Ananta Worker Todo Contract v1",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "goal_id",
    "trace_id",
    "worker",
    "todo",
    "execution",
    "control_manifest",
    "expected_result_schema"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "worker_todo_contract.v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "worker": {
      "type": "object",
      "required": [
        "executor_kind",
        "worker_profile",
        "profile_source"
      ],
      "properties": {
        "executor_kind": {
          "type": "string",
          "enum": [
            "ananta_worker",
            "opencode",
            "openai_codex_cli",
            "custom"
          ]
        },
        "worker_profile": {
          "type": "string",
          "enum": [
            "safe",
            "balanced",
            "fast"
          ]
        },
        "profile_source": {
          "type": "string",
          "enum": [
            "agent_default",
            "task_context",
            "task_override",
            "runtime_override"
          ]
        },
        "target_worker": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "todo": {
      "type": "object",
      "required": [
        "version",
        "track",
        "tasks"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "track": {
          "type": "string",
          "minLength": 1
        },
        "status_scale": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "priority_scale": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_scale": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "task_ids",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "task_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "status": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "instructions",
              "status",
              "acceptance_criteria"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "instructions": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "todo",
                  "open",
                  "planned",
                  "in_progress",
                  "blocked",
                  "done"
                ]
              },
              "priority": {
                "type": "string",
                "minLength": 1
              },
              "risk": {
                "type": "string",
                "minLength": 1
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "allowed_tools": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "expected_artifacts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "kind",
                    "required"
                  ],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "minLength": 1
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "acceptance_criteria": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "metadata": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "command_execute",
            "assistant_execute",
            "plan_only"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "runner_prompt": {
          "type": "string",
          "minLength": 1
        },
        "workspace_dir": {
          "type": "string",
          "minLength": 1
        },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "enforce_artifacts": {
          "type": "boolean"
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        }
      },
      "additionalProperties": false
    },
    "control_manifest": {
      "type": "object",
      "required": [
        "trace_id",
        "capability_id",
        "context_hash"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "capability_id": {
          "type": "string",
          "minLength": 1
        },
        "context_hash": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "expected_result_schema": {
      "type": "string",
      "const": "worker_todo_result.v1"
    },
    "schema_refs": {
      "type": "object",
      "properties": {
        "todo_schema": {
          "type": "string",
          "minLength": 1
        },
        "todo_track_schema": {
          "type": "string",
          "minLength": 1
        },
        "todo_result_schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
