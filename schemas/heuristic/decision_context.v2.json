{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_context.v2",
  "title": "DecisionContext v2",
  "description": "Rückwärtskompatibles DecisionContext Schema v2 mit TUI-Snapshot-Referenzen und SemanticOverlay-Feldern.",
  "type": "object",
  "required": ["source_surface", "ai_status"],
  "properties": {
    "source_surface": {
      "type": "string",
      "enum": ["tui_snake", "eclipse_snake", "chat_codecompass"]
    },
    "active_goal_id": {"type": ["string", "null"]},
    "active_task_id": {"type": ["string", "null"]},
    "selected_artifacts": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 5
    },
    "active_panel": {"type": ["string", "null"]},
    "recent_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_id": {"type": "string"},
          "kind": {"type": "string"},
          "normalized_value": {"type": "string"},
          "ref_id": {"type": ["string", "null"]},
          "timestamp": {"type": "number"}
        }
      },
      "maxItems": 20
    },
    "allowed_source_scopes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "ai_status": {
      "type": "string",
      "enum": ["available", "timeout", "offline", "invalid"]
    },
    "policy_state": {"type": ["string", "null"]},
    "query": {"type": ["string", "null"]},
    "context_hash": {"type": "string"},
    "tui_snapshot_ref": {
      "type": ["string", "null"],
      "description": "screen_hash des aktuellen TUI-Snapshots"
    },
    "tui_delta_ref": {
      "type": ["string", "null"],
      "description": "Kompakter Delta-Verweis: prev_hash:curr_hash"
    },
    "semantic_hash": {
      "type": ["string", "null"],
      "description": "Hash des SemanticOverlay zum Zeitpunkt der Entscheidung"
    },
    "semantic_panel": {
      "type": ["string", "null"],
      "description": "Aktives Panel aus SemanticOverlay"
    },
    "snake_head_x": {
      "type": ["integer", "null"],
      "description": "Aktuelle X-Position des lokalen Snake-Head (optional)"
    },
    "snake_head_y": {
      "type": ["integer", "null"],
      "description": "Aktuelle Y-Position des lokalen Snake-Head (optional)"
    }
  },
  "additionalProperties": false
}
