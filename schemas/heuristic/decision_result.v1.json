{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_result.v1",
  "title": "DecisionResult",
  "type": "object",
  "required": ["action_kind", "confidence", "source"],
  "properties": {
    "action_kind": {
      "type": "string",
      "enum": ["follow", "lurk", "explain", "chat", "no_action", "policy_denied"]
    },
    "answer_kind": {
      "type": ["string", "null"],
      "enum": ["source_ref", "context_summary", "no_good_match", "heuristic_answer", "ai_answer", null]
    },
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "selected_context_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "suggested_motion": {
      "type": ["object", "null"],
      "properties": {
        "dx": {"type": "integer"},
        "dy": {"type": "integer"}
      }
    },
    "answer_blocks": {
      "type": "array",
      "items": {"type": "object"}
    },
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source": {
      "type": "string",
      "enum": ["ai", "heuristic", "hybrid"]
    },
    "strategy_id": {"type": ["string", "null"]},
    "rule_id": {"type": ["string", "null"]},
    "fallback_reason": {
      "type": ["string", "null"],
      "enum": ["ai_timeout", "ai_offline", "invalid_response", "low_quality", "policy_denied", "lease_expired", null]
    }
  },
  "additionalProperties": false
}
