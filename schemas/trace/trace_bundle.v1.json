{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/trace/trace_bundle.v1.json",
  "title": "Ananta Trace Bundle v1",
  "type": "object",
  "required": [
    "schema",
    "trace_bundle_id",
    "generated_at",
    "goal_id",
    "task_ids",
    "context_hash",
    "policy_decisions",
    "approval_decisions",
    "artifact_refs",
    "provenance"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trace_bundle.v1"
    },
    "trace_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "task_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "model": {
      "type": "object",
      "required": [
        "provider",
        "model_id"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "prompt_template": {
      "type": "object",
      "required": [
        "template_id",
        "version"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "context_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "rag_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_ref",
          "retrieval_reason"
        ],
        "properties": {
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "retrieval_reason": {
            "type": "string",
            "minLength": 1
          },
          "chunk_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "policy_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "decision_id",
          "outcome",
          "reason_code"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "needs_approval"
            ]
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "approval_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "approval_id",
          "action_ref",
          "state",
          "context_hash"
        ],
        "properties": {
          "approval_id": {
            "type": "string",
            "minLength": 1
          },
          "action_ref": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "enum": [
              "approved",
              "rejected",
              "expired"
            ]
          },
          "context_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "kind",
          "task_id",
          "execution_ref",
          "content_hash",
          "provenance_summary"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "execution_ref": {
            "type": "string",
            "minLength": 1
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "provenance_summary": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "generator_component",
        "security_profile",
        "contains_full_context"
      ],
      "properties": {
        "generator_component": {
          "type": "string",
          "enum": [
            "hub",
            "worker",
            "release_gate"
          ]
        },
        "security_profile": {
          "type": "string",
          "enum": [
            "oss_core"
          ]
        },
        "contains_full_context": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 200
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

