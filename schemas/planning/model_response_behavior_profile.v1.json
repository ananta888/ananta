{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "model_response_behavior_profile.v1",
  "type": "object",
  "required": ["provider", "profile_name", "primary_output_shape_distribution", "enabled"],
  "properties": {
    "id": {"type": "string"},
    "provider": {"type": "string"},
    "model_name_pattern": {"type": ["string", "null"]},
    "model_family": {"type": ["string", "null"]},
    "profile_name": {"type": "string"},
    "observed_run_count": {"type": "integer", "minimum": 0},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "primary_output_shape_distribution": {"type": "object", "additionalProperties": {"type": "number"}},
    "format_error_distribution": {"type": "object", "additionalProperties": {"type": "number"}},
    "semantic_behavior_distribution": {"type": "object", "additionalProperties": {"type": "number"}},
    "parse_mode_distribution": {"type": "object", "additionalProperties": {"type": "number"}},
    "repair_success_distribution": {"type": "object", "additionalProperties": {"type": "number"}},
    "preferred_prompt_style": {"type": "string"},
    "preferred_parser_chain": {"type": "array", "items": {"type": "string"}},
    "preferred_repair_chain": {"type": "array", "items": {"type": "string"}},
    "mermaid_handling": {"type": "string", "enum": ["ignore", "extract_graph", "convert_to_dependencies", "forbid_in_prompt"]},
    "markdown_handling": {"type": "string", "enum": ["allow_and_strip", "forbid", "prefer"]},
    "json_contract_strength": {"type": "string", "enum": ["strict", "soft", "repair_required"]},
    "enabled": {"type": "boolean"}
  }
}
