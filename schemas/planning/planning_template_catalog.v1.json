{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/planning/planning_template_catalog.v1.json",
  "title": "Planning Template Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "templates"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "planning_template_catalog.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/template"
      }
    },
    "execution_focused_goal_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "keywords", "subtasks"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "related_standard_blueprints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "subtasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/subtask"
          }
        }
      }
    },
    "subtask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "priority"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "risk_focus": {
          "type": "string",
          "minLength": 1
        },
        "test_focus": {
          "type": "string",
          "minLength": 1
        },
        "review_focus": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
