{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/freecad/freecad_verification_artifact.v1.json",
  "type": "object",
  "required": [
    "artifact_type",
    "status",
    "checks"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "freecad_verification"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "degraded"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
