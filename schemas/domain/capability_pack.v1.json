{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/domain/capability_pack.v1.json",
  "title": "Ananta Capability Pack v1",
  "type": "object",
  "required": ["schema", "domain_id", "version", "capabilities"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "capability_pack.v1"
    },
    "domain_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "capability_id",
          "domain_id",
          "display_name",
          "category",
          "risk",
          "read_only",
          "mutating",
          "approval_required",
          "default_policy_state"
        ],
        "properties": {
          "capability_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "domain_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "read_only": {
            "type": "boolean"
          },
          "mutating": {
            "type": "boolean"
          },
          "approval_required": {
            "type": "boolean"
          },
          "default_policy_state": {
            "type": "string",
            "enum": ["allow", "deny", "approval_required", "default_deny"]
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
