{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/domain/artifact_type_pack.v1.json",
  "title": "Ananta Artifact Type Pack v1",
  "type": "object",
  "required": ["schema", "domain_id", "version", "artifact_types"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "artifact_type_pack.v1"
    },
    "domain_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "artifact_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_type_id",
          "domain_id",
          "display_name",
          "schema_ref",
          "render_hint",
          "safety_classification",
          "allowed_clients"
        ],
        "properties": {
          "artifact_type_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "domain_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "render_hint": {
            "type": "string",
            "enum": ["text", "json", "table", "markdown", "binary", "mixed"]
          },
          "safety_classification": {
            "type": "string",
            "enum": ["public", "internal", "sensitive", "restricted"]
          },
          "allowed_clients": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["cli", "tui", "web", "bridge", "api"]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
