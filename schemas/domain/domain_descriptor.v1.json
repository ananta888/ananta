{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/domain/domain_descriptor.v1.json",
  "title": "Ananta Domain Descriptor v1",
  "type": "object",
  "required": [
    "schema",
    "domain_id",
    "display_name",
    "version",
    "lifecycle_status",
    "runtime_status",
    "owner",
    "description",
    "supported_clients",
    "source_paths",
    "capability_pack",
    "context_schemas",
    "artifact_schemas",
    "policy_packs",
    "rag_profiles",
    "bridge_adapter_type"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "domain_descriptor.v1"
    },
    "domain_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "planned",
        "foundation_only",
        "runtime_mvp",
        "runtime_complete",
        "deferred",
        "blocked",
        "deprecated"
      ]
    },
    "runtime_status": {
      "type": "string",
      "enum": [
        "descriptor_only",
        "runtime_unavailable",
        "runtime_degraded",
        "runtime_available"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_clients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["cli", "tui", "web", "bridge", "api"]
      },
      "uniqueItems": true
    },
    "source_paths": {
      "type": "object",
      "required": ["descriptor_root", "code_paths", "docs_paths"],
      "properties": {
        "descriptor_root": {
          "type": "string",
          "minLength": 1
        },
        "code_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "docs_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "capability_pack": {
      "type": "string",
      "minLength": 1
    },
    "context_schemas": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_schemas": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "policy_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rag_profiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "bridge_adapter_type": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
