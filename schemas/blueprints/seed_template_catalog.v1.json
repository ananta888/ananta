{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/blueprints/seed_template_catalog.v1.json",
  "title": "Seed Template Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "appendixes", "team_types", "templates"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "seed_template_catalog.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "appendixes": {
      "type": "object",
      "description": "Named text fragments referenced as {{appendix:name}} in prompt_template.",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "team_types": {
      "type": "object",
      "description": "Per-team-type role linkage and role profile defaults.",
      "additionalProperties": {
        "$ref": "#/$defs/team_type_config"
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/template"
      }
    }
  },
  "$defs": {
    "team_type_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "roles"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role_link"
          }
        },
        "role_profile_defaults": {
          "type": "object",
          "description": "capability_defaults, risk_profile, verification_defaults per role name.",
          "additionalProperties": {
            "$ref": "#/$defs/role_profile"
          }
        }
      }
    },
    "role_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "template_name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "template_name": { "type": "string", "minLength": 1 }
      }
    },
    "role_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_defaults", "risk_profile", "verification_defaults"],
      "properties": {
        "capability_defaults": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_profile": {
          "type": "string",
          "enum": ["low", "balanced", "high", "strict"]
        },
        "verification_defaults": {
          "type": "object",
          "required": ["required", "gates"],
          "properties": {
            "required": { "type": "boolean" },
            "gates": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "team_type", "prompt_template"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "team_type": { "type": "string", "minLength": 1 },
        "prompt_template": { "type": "string", "minLength": 1 }
      }
    }
  }
}
