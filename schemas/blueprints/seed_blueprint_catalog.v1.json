{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/schemas/blueprints/seed_blueprint_catalog.v1.json",
  "title": "Seed Blueprint Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "blueprints"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "seed_blueprint_catalog.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "blueprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/blueprint"
      }
    }
  },
  "$defs": {
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "roles", "artifacts"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "base_team_type_name": {
          "type": ["string", "null"]
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/role"
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifact"
          }
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "template_name", "sort_order", "is_required", "config"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "template_name": {
          "type": "string",
          "minLength": 1
        },
        "sort_order": {
          "type": "integer"
        },
        "is_required": {
          "type": "boolean"
        },
        "config": {
          "type": "object"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "title", "description", "sort_order", "payload"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["task", "policy"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "sort_order": {
          "type": "integer"
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
