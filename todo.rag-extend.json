{
  "name": "ananta_rag_policy_context_plan",
  "version": "0.1",
  "goal": "RAG-Kontextauswahl und sichere Worker-/LLM-Policy-Steuerung kombinieren",
  "principles": [
    "Policy-Filter vor Context-Building",
    "Default-Deny für externe/cloud LLMs",
    "Least-Privilege pro Worker",
    "Kontext-Minimierung statt Vollzugriff",
    "Rohdaten und Secrets niemals an Cloud-LLMs",
    "Graph-Kanten dürfen nicht automatisch Policy-Grenzen überschreiten"
  ],
  "phases": [
    {
      "id": "phase_1_model",
      "title": "Grundmodell für ContextGraph und PolicyGraph definieren",
      "priority": "critical",
      "tasks": [
        {
          "id": "model_001",
          "title": "Datenklassen definieren",
          "status": "todo",
          "output": "data_class enum",
          "items": [
            "public",
            "internal_low",
            "internal_medium",
            "internal_high",
            "confidential",
            "secret",
            "credential",
            "customer_data",
            "legal",
            "security_sensitive"
          ]
        },
        {
          "id": "model_002",
          "title": "LLM-Scope definieren",
          "status": "todo",
          "output": "llm_scope enum",
          "items": [
            "local_only",
            "trusted_private_cloud",
            "external_cloud_allowed",
            "no_llm"
          ]
        },
        {
          "id": "model_003",
          "title": "Worker-Profil modellieren",
          "status": "todo",
          "fields": [
            "worker_id",
            "worker_role",
            "task_kinds",
            "allowed_llm_scopes",
            "allowed_data_classes",
            "denied_data_classes",
            "allowed_tools",
            "max_context_sensitivity",
            "can_expand_graph",
            "can_view_raw_code",
            "can_view_summaries",
            "can_write_files",
            "can_call_external_services"
          ]
        },
        {
          "id": "model_004",
          "title": "RAG-Node-Metadaten erweitern",
          "status": "todo",
          "fields": [
            "id",
            "kind",
            "file",
            "domain",
            "owner",
            "source_scope",
            "sensitivity",
            "allowed_llm_scopes",
            "allowed_worker_roles",
            "contains_secrets",
            "contains_customer_data",
            "redaction_required",
            "summary_allowed",
            "raw_allowed"
          ]
        },
        {
          "id": "model_005",
          "title": "RAG-Edge-Metadaten erweitern",
          "status": "todo",
          "fields": [
            "source",
            "target",
            "type",
            "confidence",
            "heuristic",
            "sensitivity_propagation",
            "traversal_policy",
            "allowed_worker_roles",
            "allowed_llm_scopes"
          ]
        }
      ]
    },
    {
      "id": "phase_2_rag_helper",
      "title": "rag-helper / codecompass erweitern",
      "priority": "high",
      "tasks": [
        {
          "id": "rag_001",
          "title": "Sensitivity-Klassifikation in rag-helper einbauen",
          "status": "todo",
          "details": [
            "Dateipfade auswerten",
            "Dateinamen auswerten",
            "Keywords erkennen",
            "Secrets-Heuristik ergänzen",
            "Customer-/Legal-/Security-Kontexte markieren"
          ]
        },
        {
          "id": "rag_002",
          "title": "Node-Labels für Datenklassen erzeugen",
          "status": "todo",
          "example": {
            "sensitivity": "internal_high",
            "contains_secrets": false,
            "summary_allowed": true,
            "raw_allowed": false
          }
        },
        {
          "id": "rag_003",
          "title": "Edge-Policy für Graph-Traversal erzeugen",
          "status": "todo",
          "example": {
            "type": "calls",
            "sensitivity_propagation": "target_max",
            "traversal_policy": "check_target_policy"
          }
        },
        {
          "id": "rag_004",
          "title": "Redacted/Summary-Kontexte erzeugen",
          "status": "todo",
          "outputs": [
            "context_raw.jsonl",
            "context_summary.jsonl",
            "context_redacted.jsonl"
          ]
        },
        {
          "id": "rag_005",
          "title": "Manifest um Security-Statistiken erweitern",
          "status": "todo",
          "fields": [
            "node_count_by_sensitivity",
            "secret_candidate_count",
            "cloud_allowed_context_count",
            "raw_only_local_count",
            "redaction_required_count"
          ]
        }
      ]
    },
    {
      "id": "phase_3_policy_engine",
      "title": "Policy Engine vor RAG-Kontextbau",
      "priority": "critical",
      "tasks": [
        {
          "id": "policy_001",
          "title": "PolicyDecision-Modell bauen",
          "status": "todo",
          "fields": [
            "allowed",
            "reason",
            "effective_llm_scope",
            "allowed_context_modes",
            "denied_node_ids",
            "redaction_required",
            "max_context_tokens"
          ]
        },
        {
          "id": "policy_002",
          "title": "Worker gegen Task und LLM prüfen",
          "status": "todo",
          "rules": [
            "Worker darf gewählten LLM-Scope verwenden",
            "Worker darf gewählte Tools verwenden",
            "Worker darf Task-Kind ausführen",
            "Worker darf Datenklasse sehen",
            "Cloud-LLM bekommt keine raw/confidential/secret/customer_data Inhalte"
          ]
        },
        {
          "id": "policy_003",
          "title": "Graph-Traversal absichern",
          "status": "todo",
          "rules": [
            "Jeder Zielknoten wird separat geprüft",
            "Kanten dürfen sensitivity erhöhen",
            "Nicht erlaubte Nachbarn werden nicht expandiert",
            "Unsichere Kanten können nur lokale Worker nutzen",
            "Confidence unter Schwelle wird optional ignoriert"
          ]
        },
        {
          "id": "policy_004",
          "title": "Default-Deny implementieren",
          "status": "todo",
          "rules": [
            "Unklassifizierte Nodes gelten mindestens als internal_medium",
            "Unbekannter Worker bekommt keinen Kontext",
            "Unbekannter LLM-Provider gilt als external_cloud",
            "Fehlende Policy blockiert Ausgabe"
          ]
        }
      ]
    },
    {
      "id": "phase_4_context_builder",
      "title": "Sicheren Context Builder bauen",
      "priority": "critical",
      "tasks": [
        {
          "id": "context_001",
          "title": "Pipeline definieren",
          "status": "todo",
          "pipeline": [
            "receive_task",
            "resolve_worker_profile",
            "resolve_llm_scope",
            "semantic_candidate_search",
            "graph_expansion",
            "policy_filter_nodes",
            "policy_filter_edges",
            "select_context_mode",
            "redact_if_required",
            "build_final_context"
          ]
        },
        {
          "id": "context_002",
          "title": "Kontext-Modi einführen",
          "status": "todo",
          "modes": [
            "raw_code",
            "minimal_code",
            "symbol_summary",
            "architecture_summary",
            "redacted_summary",
            "public_only"
          ]
        },
        {
          "id": "context_003",
          "title": "Cloud-Kontext minimieren",
          "status": "todo",
          "rules": [
            "Nur benötigte Ausschnitte",
            "Keine vollständigen Repositories",
            "Keine secrets",
            "Keine credentials",
            "Keine Kundendaten",
            "Interne Namen optional pseudonymisieren",
            "Graph-Nachbarschaft stark begrenzen"
          ]
        },
        {
          "id": "context_004",
          "title": "Lokalen Kontext breiter erlauben",
          "status": "todo",
          "rules": [
            "Mehr raw_code erlaubt",
            "Breitere Graph-Expansion erlaubt",
            "Sensible Inhalte trotzdem loggen und markieren",
            "Secrets auch lokal nur wenn explizit nötig"
          ]
        }
      ]
    },
    {
      "id": "phase_5_worker_routing",
      "title": "Worker- und LLM-Routing integrieren",
      "priority": "high",
      "tasks": [
        {
          "id": "route_001",
          "title": "Task-Router mit Policy koppeln",
          "status": "todo",
          "inputs": [
            "task_kind",
            "requested_model",
            "requested_tools",
            "required_context_scope",
            "user_permissions"
          ],
          "outputs": [
            "selected_worker",
            "selected_llm_scope",
            "allowed_context_mode",
            "policy_decision"
          ]
        },
        {
          "id": "route_002",
          "title": "Worker Capability Registry bauen",
          "status": "todo",
          "example": {
            "worker_id": "refactor_local_worker",
            "allowed_llm_scopes": [
              "local_only"
            ],
            "allowed_data_classes": [
              "public",
              "internal_low",
              "internal_medium",
              "internal_high"
            ],
            "allowed_tools": [
              "read_repo",
              "write_patch",
              "run_tests"
            ]
          }
        },
        {
          "id": "route_003",
          "title": "Cloud Worker stark einschränken",
          "status": "todo",
          "example": {
            "worker_id": "cloud_summary_worker",
            "allowed_llm_scopes": [
              "external_cloud_allowed"
            ],
            "allowed_data_classes": [
              "public",
              "internal_low"
            ],
            "allowed_context_modes": [
              "redacted_summary",
              "public_only"
            ],
            "can_view_raw_code": false
          }
        }
      ]
    },
    {
      "id": "phase_6_audit",
      "title": "Audit, Logging und Nachvollziehbarkeit",
      "priority": "high",
      "tasks": [
        {
          "id": "audit_001",
          "title": "Jede Kontextfreigabe protokollieren",
          "status": "todo",
          "fields": [
            "task_id",
            "worker_id",
            "llm_scope",
            "model_name",
            "node_ids_sent",
            "context_mode",
            "redaction_applied",
            "policy_decision",
            "timestamp"
          ]
        },
        {
          "id": "audit_002",
          "title": "Blockierte Inhalte protokollieren",
          "status": "todo",
          "fields": [
            "blocked_node_id",
            "reason",
            "worker_id",
            "requested_llm_scope",
            "sensitivity"
          ]
        },
        {
          "id": "audit_003",
          "title": "Dry-Run Policy Check bauen",
          "status": "todo",
          "description": "Vor Ausführung anzeigen, welcher Kontext an welchen Worker/LLM gehen würde."
        },
        {
          "id": "audit_004",
          "title": "Context Diff speichern",
          "status": "todo",
          "description": "Unterschied zwischen Kandidaten-Kontext und wirklich freigegebenem Kontext sichtbar machen."
        }
      ]
    },
    {
      "id": "phase_7_ui",
      "title": "User-Steuerung im UI",
      "priority": "medium",
      "tasks": [
        {
          "id": "ui_001",
          "title": "Task-Dialog um Sicherheitsoptionen erweitern",
          "status": "todo",
          "fields": [
            "allow_cloud_llm",
            "allow_raw_code",
            "max_sensitivity",
            "allowed_domains",
            "excluded_domains",
            "context_mode"
          ]
        },
        {
          "id": "ui_002",
          "title": "Policy-Vorschau anzeigen",
          "status": "todo",
          "description": "Vor Start zeigen: Worker, LLM-Scope, erlaubte Datenklassen, blockierte Bereiche."
        },
        {
          "id": "ui_003",
          "title": "Warnung bei Cloud-Kontext",
          "status": "todo",
          "rules": [
            "Cloud-LLM aktiv",
            "Interner Kontext wird verwendet",
            "Redaction aktiv",
            "Raw-Code blockiert"
          ]
        }
      ]
    },
    {
      "id": "phase_8_tests",
      "title": "Tests und Sicherheitsfälle",
      "priority": "critical",
      "tasks": [
        {
          "id": "test_001",
          "title": "Cloud-Worker darf Secret-Node nicht sehen",
          "status": "todo"
        },
        {
          "id": "test_002",
          "title": "Cloud-Worker darf nicht über Edge zu Secret-Node expandieren",
          "status": "todo"
        },
        {
          "id": "test_003",
          "title": "Local-Worker darf raw_code nur mit passender Rolle sehen",
          "status": "todo"
        },
        {
          "id": "test_004",
          "title": "Unklassifizierte Nodes werden nicht an Cloud gesendet",
          "status": "todo"
        },
        {
          "id": "test_005",
          "title": "Redaction entfernt Tokens, Keys, Passwörter und Kundendaten",
          "status": "todo"
        },
        {
          "id": "test_006",
          "title": "Audit-Log enthält jede Kontextfreigabe",
          "status": "todo"
        },
        {
          "id": "test_007",
          "title": "Policy-Dry-Run verändert keine Daten",
          "status": "todo"
        }
      ]
    }
  ],
  "minimal_mvp": [
    "WorkerProfile-Modell",
    "DataClass/Sensitivity-Modell",
    "LLMScope-Modell",
    "PolicyEngine mit Default-Deny",
    "ContextBuilder mit Policy-Filter",
    "Audit-Log",
    "Tests für Cloud-LLM-Verbot"
  ],
  "recommended_order": [
    "model_001",
    "model_002",
    "model_003",
    "model_004",
    "policy_001",
    "policy_002",
    "policy_004",
    "context_001",
    "context_002",
    "route_001",
    "audit_001",
    "test_001",
    "test_002"
  ]
}
