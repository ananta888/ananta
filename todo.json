        {
          "id": "task-6-3",
          "title": "Chat- und Response-Endpunkte auf Hub-Pipeline abbilden",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "POST /v1/chat/completions",
            "POST /v1/responses"
          ]
        },
        {
          "id": "task-6-4",
          "title": "Datei-API im OpenAI-Stil ergänzen",
          "status": "completed",
          "priority": "high",
          "deliverables": [
            "POST /v1/files",
            "GET /v1/files",
            "GET /v1/files/{id}"
          ]
        },
        {
          "id": "task-6-5",
          "title": "Ananta-spezifische Erweiterungen optional bereitstellen",
          "status": "completed",
          "priority": "medium",
          "deliverables": [
            "trace_id",
            "artifacts",
            "context_sources",
            "worker_runs",
            "verification"
          ]
        }
      ]
    },
    {
      "id": "phase-7-task-pipeline-migration",
      "title": "Bestehende Task- und LLM-Pipelines auf den neuen Kern migrieren",
      "status": "todo",
      "tasks": [
        {
