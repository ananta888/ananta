{
  "project": "ananta",
  "branch": "main",
  "title": "Hub zu zentralem RAG- und Artifact-System ausbauen",
  "version": 1,
  "goals": [
    {
      "id": "goal-hub-rag-core",
      "title": "Hub als zentrales RAG-Control-Plane etablieren",
      "description": "Der Hub wird zentrale Stelle für Retrieval, Kontextselektion, Ergebnisverwaltung und Rückführung in Memory/RAG. Worker bleiben für Ausführung und Tool-Nutzung zuständig.",
      "priority": "critical",
      "status": "todo"
    },
    {
      "id": "goal-worker-tools-preserved",
      "title": "Worker-Tooling erhalten",
      "description": "Codex, SGPT, OpenCode, Aider, Mistral Code und ähnliche Backends bleiben als Werkzeuge der Worker erhalten und werden nicht in den Hub verlagert.",
      "priority": "critical",
      "status": "todo"
    },
    {
      "id": "goal-openai-compat",
      "title": "OpenAI-kompatible Standardschnittstelle bereitstellen",
      "description": "Der Hub bietet eine API im Stil von OpenAI, damit externe Plugins, Agenten und Clients Ananta als Backend verwenden können.",
      "priority": "high",
      "status": "todo"
    },
    {
      "id": "goal-arbitrary-file-ingestion",
      "title": "Beliebige Dateiformate in den Hub laden und verwalten",
      "description": "Der Hub soll beliebige Dateien als Artefakte speichern, analysieren, extrahieren, indexieren und für Retrieval nutzbar machen.",
      "priority": "critical",
      "status": "todo"
    }
  ],
  "phases": [
    {
      "id": "phase-1-architecture-refactor",
      "title": "Architekturkern vereinheitlichen",
      "status": "completed",
      "tasks": [
        {
          "id": "task-1-1",
          "title": "Bestehenden HybridOrchestrator in generischen RAG-Service überführen",
          "status": "completed",
          "priority": "critical",
          "files": [
            "agent/hybrid_orchestrator.py"
          ],
          "deliverables": [
            "agent/services/rag_service.py",
            "agent/services/retrieval_service.py",
            "agent/services/context_bundle_service.py"
          ],
          "notes": [
            "Bestehende repository_map-, semantic_search- und agentic_search-Fähigkeiten übernehmen",
            "Bisherigen SGPT-spezifischen Zugriff entkoppeln"
          ]
        },
        {
          "id": "task-1-2",
          "title": "Zentrale Service-Schicht für Retrieval und Kontextpakete einführen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "RAG-Service als zentrale Backend-Komponente",
            "Einheitliche Schnittstelle für taskbezogene Kontextselektion",
            "Kontextpakete für Worker"
          ]
        },
        {
          "id": "task-1-3",
          "title": "SGPT-Kontext-Endpoints auf den neuen Kern umstellen",
          "status": "completed",
          "priority": "high",
          "files": [
            "agent/routes/sgpt.py"
          ],
          "deliverables": [
            "/api/sgpt/context als Adapter auf den zentralen RAG-Service",
            "/api/sgpt/execute optional weiterhin mit zentralem Retrieval"
          ]
        }
      ]
    },
    {
      "id": "phase-2-artifact-layer",
      "title": "Artifact- und Datei-Layer aufbauen",
      "status": "completed",
      "tasks": [
        {
          "id": "task-2-1",
          "title": "Raw Artifact Store einführen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "Speicherung beliebiger Dateien",
            "Hashing",
            "MIME-Type-Erkennung",
            "Versionierungsvorbereitung"
          ]
        },
        {
          "id": "task-2-2",
          "title": "Datenmodell für Artefakte und extrahierte Inhalte ergänzen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "artifacts",
            "artifact_versions",
            "extracted_documents",
            "knowledge_collections",
            "knowledge_links"
          ]
        },
        {
          "id": "task-2-3",
          "title": "Upload-API für beliebige Dateien bereitstellen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "POST /artifacts/upload",
            "GET /artifacts",
            "GET /artifacts/{id}",
            "POST /artifacts/{id}/extract"
          ]
        }
      ]
    },
    {
      "id": "phase-3-extraction-indexing",
      "title": "Extraktion und Indexierung für beliebige Formate",
      "status": "completed",
      "tasks": [
        {
          "id": "task-3-1",
          "title": "Text- und Codeformate extrahieren",
          "status": "completed",
          "priority": "high",
          "formats": [
            "txt",
            "md",
            "rst",
            "json",
            "yaml",
            "xml",
            "csv",
            "py",
            "ts",
            "js",
            "java",
            "go",
            "rs",
            "c",
            "cpp",
            "cs",
            "php"
          ]
        },
        {
          "id": "task-3-2",
          "title": "PDF und Office-Dokumente extrahieren",
          "status": "completed",
          "priority": "high",
          "formats": [
            "pdf",
            "docx",
            "xlsx",
            "pptx",
            "odt",
            "ods",
            "odp"
          ]
        },
        {
          "id": "task-3-3",
          "title": "Bilder, Audio, Video und Archive als Artefakte unterstützen",
          "status": "completed",
          "priority": "medium",
          "formats": [
            "png",
            "jpg",
            "webp",
            "mp3",
            "wav",
            "mp4",
            "mkv",
            "zip",
            "tar",
            "gz",
            "eml",
            "msg"
          ],
          "notes": [
            "Nicht jedes Format muss sofort semantisch voll durchsuchbar sein",
            "Mindestens Speicherung, Inventarisierung und Referenzierung sicherstellen"
          ]
        },
        {
          "id": "task-3-4",
          "title": "Extraktionspipeline mit Fallback-Modi implementieren",
          "status": "completed",
          "priority": "high",
          "deliverables": [
            "raw-only",
            "metadata-only",
            "text-extracted",
            "fully-indexed"
          ]
        }
      ]
    },
    {
      "id": "phase-4-worker-context-routing",
      "title": "Worker-Aufträge mit selektivem Kontext umstellen",
      "status": "completed",
      "tasks": [
        {
          "id": "task-4-1",
          "title": "Kontext-Bundles pro Worker erzeugen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "context_bundles",
            "retrieval_runs",
            "worker_execution_context"
          ]
        },
        {
          "id": "task-4-2",
          "title": "Task-Delegation so umbauen, dass Worker nur relevante Teilkontexte erhalten",
          "status": "completed",
          "priority": "critical",
          "files": [
            "agent/routes/tasks/orchestration.py"
          ],
          "notes": [
            "Hub bleibt Eigentümer von Routing und Ergebnisverwaltung",
            "Worker erhalten schlanke Aufträge mit instructions, context, allowed_tools und expected_output_schema"
          ]
        },
        {
          "id": "task-4-3",
          "title": "Worker-Jobs als eigene Entität einführen",
          "status": "completed",
          "priority": "high",
          "deliverables": [
            "worker_jobs",
            "worker_results"
          ]
        },
        {
          "id": "task-4-4",
          "title": "Worker-Tooling explizit als Capabilities modellieren",
          "status": "completed",
          "priority": "high",
          "deliverables": [
            "Capability-Mapping für sgpt",
            "Capability-Mapping für codex",
            "Capability-Mapping für opencode",
            "Capability-Mapping für aider",
            "Capability-Mapping für mistral_code"
          ]
        }
      ]
    },
    {
      "id": "phase-5-result-memory",
      "title": "Ergebnisse in Hub-Memory und RAG zurückführen",
      "status": "completed",
      "tasks": [
        {
          "id": "task-5-1",
          "title": "Result-Memory-Service aufbauen",
          "status": "completed",
          "priority": "critical",
          "deliverables": [
            "agent/services/result_memory_service.py"
          ]
        },
        {
          "id": "task-5-2",
          "title": "Worker-Ergebnisse strukturiert speichern und erneut indexieren",
          "status": "completed",
          "priority": "critical",
          "notes": [
            "Nicht nur Task-History pflegen",
            "Zusammenfassungen, Artefakt-Referenzen und Retrieval-relevante Inhalte wieder einlernbar machen"
          ]
        },
        {
          "id": "task-5-3",
          "title": "Provenance, Traceability und Verification mit Result-Memory verbinden",
          "status": "completed",
          "priority": "high"
        }
      ]
    },
    {
      "id": "phase-6-openai-compatible-api",
      "title": "OpenAI-kompatible Außen-API einführen",
      "status": "completed",
      "tasks": [
        {
          "id": "task-6-1",
          "title": "Route-Modul für OpenAI-kompatible Endpunkte anlegen",
          "status": "completed",
