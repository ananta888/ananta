  "non_goals_initial": [
    "Worker-Tooling entfernen",
    "Komplette UI-Neuentwicklung",
    "Alle Dateiformate sofort perfekt semantisch unterstützen",
    "Bestehende Task-/Worker-Architektur abrupt ersetzen"
  ],
  "acceptance_criteria": [
    "Hub kann beliebige Dateien als Artefakte speichern",
    "Hub kann extrahierbare Inhalte indexieren und für Retrieval nutzen",
    "Worker erhalten nur selektive, relevante Kontextpakete",
    "Worker können weiterhin Codex, SGPT, OpenCode, Aider und ähnliche Tools verwenden",
    "Worker-Ergebnisse werden strukturiert zurückgeführt und wieder im Hub nutzbar gemacht",
    "Externe Clients können über eine OpenAI-kompatible API mit dem System sprechen"
  ]
