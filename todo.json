        },
        {
          "id": "task-8-2",
          "title": "Knowledge Collections und Artifact-Ansichten ergänzen",
          "status": "todo",
          "priority": "high"
        },
        {
          "id": "task-8-3",
          "title": "Kontextquellen pro Task und Worker sichtbar machen",
