keycloak.ananta.de {
    reverse_proxy keycloak:8080
}

webrtc.ananta.de {
    # WebSocket upgrade für /signaling (zukünftige native WS-Unterstützung)
    @ws {
        path /signaling
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @ws rendezvous:5000

    reverse_proxy rendezvous:5000
}
