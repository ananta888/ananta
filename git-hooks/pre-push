#!/usr/bin/env python3
import sys
import subprocess
import os

def run_check():
    print("--- Running Pre-Push Architecture & Quality Checks ---")

    # We use the standard mode for pre-push
    # It includes format, lint, types, arch and fast tests
    try:
        # Check if python is available
        python_exe = sys.executable

        # Run scripts/check_pipeline.py --mode standard
        result = subprocess.run([python_exe, "scripts/check_pipeline.py", "--mode", "standard"], check=False)

        if result.returncode == 0:
            print("\n✅ Pre-push checks passed. Proceeding with push.")
            return True
        else:
            print("\n❌ Pre-push checks failed. Push aborted.")
            print("Please fix the issues reported above or use --no-verify if absolutely necessary.")
            return False

    except Exception as e:
        print(f"Error executing pre-push checks: {e}")
        return False

if __name__ == "__main__":
    if not run_check():
        sys.exit(1)
    sys.exit(0)
