{
  "name": "ananta-vscode-extension",
  "displayName": "Ananta",
  "description": "Thin VS Code client for Ananta goal/task runtime workflows.",
  "version": "0.1.0",
  "publisher": "ananta888",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ananta888/ananta.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "resources/**",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "activationEvents": [
    "onCommand:ananta.checkHealth",
    "onCommand:ananta.configureProfile",
    "onCommand:ananta.storeToken",
    "onCommand:ananta.clearToken",
    "onCommand:ananta.openStatusView",
    "onCommand:ananta.submitGoal",
    "onCommand:ananta.analyzeSelection",
    "onCommand:ananta.reviewFile",
    "onCommand:ananta.patchPlan",
    "onCommand:ananta.projectNew",
    "onCommand:ananta.projectEvolve",
    "onView:ananta.statusView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ananta.checkHealth",
        "title": "Ananta: Check Backend Health"
      },
      {
        "command": "ananta.configureProfile",
        "title": "Ananta: Open Settings"
      },
      {
        "command": "ananta.storeToken",
        "title": "Ananta: Store Auth Token"
      },
      {
        "command": "ananta.clearToken",
        "title": "Ananta: Clear Auth Token"
      },
      {
        "command": "ananta.openStatusView",
        "title": "Ananta: Open Status View"
      },
      {
        "command": "ananta.submitGoal",
        "title": "Ananta: Submit Goal",
        "enablement": "ananta.capability.submitGoal"
      },
      {
        "command": "ananta.analyzeSelection",
        "title": "Ananta: Analyze Selection",
        "enablement": "ananta.capability.analyzeSelection"
      },
      {
        "command": "ananta.reviewFile",
        "title": "Ananta: Review File",
        "enablement": "ananta.capability.reviewFile"
      },
      {
        "command": "ananta.patchPlan",
        "title": "Ananta: Patch Plan",
        "enablement": "ananta.capability.patchPlan"
      },
      {
        "command": "ananta.projectNew",
        "title": "Ananta: Project New",
        "enablement": "ananta.capability.projectNew"
      },
      {
        "command": "ananta.projectEvolve",
        "title": "Ananta: Project Evolve",
        "enablement": "ananta.capability.projectEvolve"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ananta",
          "title": "Ananta",
          "icon": "resources/ananta.svg"
        }
      ]
    },
    "views": {
      "ananta": [
        {
          "id": "ananta.statusView",
          "name": "Status"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "ananta.analyzeSelection",
          "when": "editorTextFocus && editorHasSelection && ananta.capability.analyzeSelection",
          "group": "navigation@20"
        },
        {
          "command": "ananta.reviewFile",
          "when": "editorTextFocus && ananta.capability.reviewFile",
          "group": "navigation@21"
        },
        {
          "command": "ananta.patchPlan",
          "when": "editorTextFocus && ananta.capability.patchPlan",
          "group": "navigation@22"
        },
        {
          "command": "ananta.submitGoal",
          "when": "editorTextFocus && ananta.capability.submitGoal",
          "group": "navigation@23"
        }
      ]
    },
    "configuration": {
      "title": "Ananta",
      "properties": {
        "ananta.baseUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL for the Ananta backend API."
        },
        "ananta.profileId": {
          "type": "string",
          "default": "default",
          "description": "Logical profile id used for runtime context selection."
        },
        "ananta.runtimeTarget": {
          "type": "string",
          "default": "local",
          "enum": [
            "local",
            "staging",
            "production"
          ],
          "description": "Named runtime target used by diagnostics and logs."
        },
        "ananta.auth.mode": {
          "type": "string",
          "default": "session_token",
          "enum": [
            "none",
            "session_token",
            "personal_token"
          ],
          "description": "Authentication mode used for backend requests."
        },
        "ananta.auth.secretStorageKey": {
          "type": "string",
          "default": "ananta.auth.token",
          "description": "SecretStorage key used for auth token lookup."
        },
        "ananta.timeoutMs": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "HTTP timeout in milliseconds for backend requests."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "package": "npm run compile && mkdir -p dist && vsce package --out dist/ananta-vscode-extension.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^8.57.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "vsce": "^2.15.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}
