<?xml version="1.0" encoding="UTF-8"?>
<plugin>
   <extension
         point="org.eclipse.ui.commands">
      <command
            categoryId="io.ananta.eclipse.category"
            description="Analyze current editor context with Ananta"
            id="io.ananta.eclipse.command.analyze"
            name="Ananta Analyze"/>
      <command
            categoryId="io.ananta.eclipse.category"
            description="Review selected editor context with Ananta"
            id="io.ananta.eclipse.command.review"
            name="Ananta Review"/>
      <command
            categoryId="io.ananta.eclipse.category"
            description="Generate patch plan through Ananta"
            id="io.ananta.eclipse.command.patch"
            name="Ananta Patch Plan"/>
      <command
            categoryId="io.ananta.eclipse.category"
            description="Start new project flow in Ananta"
            id="io.ananta.eclipse.command.new_project"
            name="Ananta Project New"/>
      <command
            categoryId="io.ananta.eclipse.category"
            description="Evolve project flow in Ananta"
            id="io.ananta.eclipse.command.evolve_project"
            name="Ananta Project Evolve"/>
   </extension>

   <extension
         point="org.eclipse.ui.commandCategories">
      <category
            id="io.ananta.eclipse.category"
            name="Ananta"/>
   </extension>

   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="io.ananta.eclipse.runtime.commands.handlers.AnalyzeCommandHandler"
            commandId="io.ananta.eclipse.command.analyze"/>
      <handler
            class="io.ananta.eclipse.runtime.commands.handlers.ReviewCommandHandler"
            commandId="io.ananta.eclipse.command.review"/>
      <handler
            class="io.ananta.eclipse.runtime.commands.handlers.PatchCommandHandler"
            commandId="io.ananta.eclipse.command.patch"/>
      <handler
            class="io.ananta.eclipse.runtime.commands.handlers.NewProjectCommandHandler"
            commandId="io.ananta.eclipse.command.new_project"/>
      <handler
            class="io.ananta.eclipse.runtime.commands.handlers.EvolveProjectCommandHandler"
            commandId="io.ananta.eclipse.command.evolve_project"/>
   </extension>

   <extension
         point="org.eclipse.ui.views">
      <view
            id="io.ananta.eclipse.view.goal"
            name="Ananta Goal Panel"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.task_list"
            name="Ananta Task List"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.task_detail"
            name="Ananta Task Detail"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.artifact"
            name="Ananta Artifact View"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.approval_queue"
            name="Ananta Approval Queue"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.audit"
            name="Ananta Audit Explorer"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.repair"
            name="Ananta Repair Explorer"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.tui_status"
            name="Ananta TUI Status"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
      <view
            id="io.ananta.eclipse.view.policy_fallback"
            name="Ananta Policy and Browser Fallback"
            class="io.ananta.eclipse.runtime.views.EclipseViewsExtensionRegistry"/>
   </extension>
</plugin>
