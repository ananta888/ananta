# Docker Compose environment variables
# Copy this file to .env and adjust as needed

# Cross-platform path resolution for Git Bash / MSYS on Windows
# Set to 1 if you encounter 'invalid volume specification' errors in Git Bash
COMPOSE_CONVERT_WINDOWS_PATHS=0

# Port Configuration
HUB_PORT=5000
ALPHA_PORT=5001
BETA_PORT=5002
GAMMA_PORT=5003
DELTA_PORT=5004
LMSTUDIO_PROXY_PORT=12340
FRONTEND_PORT=4200
POSTGRES_PORT=5432
REDIS_PORT=6379
HTTP_PORT=80
HTTPS_PORT=443
LOKI_PORT=3100
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# Database Configuration
# GENERATE NEW PASSWORDS FOR PRODUCTION!
POSTGRES_USER=ananta
POSTGRES_PASSWORD=replace_this_with_a_secure_password_123!
POSTGRES_DB=ananta
# Hub file descriptor limits (helps under heavy E2E/login load)
HUB_NOFILE_SOFT=8192
HUB_NOFILE_HARD=65535

# Grafana Configuration
GRAFANA_PASSWORD=replace_this_with_a_secure_password_456!

# Service URLs
LMSTUDIO_URL=http://192.168.56.1:1234/v1
OLLAMA_URL=http://host.docker.internal:11434/api/generate
LMSTUDIO_API_MODE=chat
E2E_OLLAMA_URL=http://host.docker.internal:11434/api/generate
E2E_LMSTUDIO_URL=http://host.docker.internal:1234/v1
OLLAMA_VULKAN=1
OLLAMA_WSL_LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64
OLLAMA_WSL_VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/dzn_icd.json
COMPOSE_OLLAMA_URL=http://ollama:11434/api/generate
COMPOSE_LMSTUDIO_URL=http://192.168.56.1:1234/v1
COMPOSE_DEFAULT_PROVIDER=ollama
COMPOSE_DEFAULT_MODEL=qwen2.5-coder:7b
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=WARNING
AUTH_TEST_ENDPOINTS_ENABLED=0
HUB_CAN_BE_WORKER=0

# AI Agent Configuration
# IMPORTANT: Change these tokens for production use!
# They are used for inter-agent communication security.
AGENT_TOKEN_HUB=generate_a_random_token_for_hub
AGENT_TOKEN_ALPHA=generate_a_random_token_for_alpha
AGENT_TOKEN_BETA=generate_a_random_token_for_beta
AGENT_TOKEN_GAMMA=generate_a_random_token_for_gamma
AGENT_TOKEN_DELTA=generate_a_random_token_for_delta
# Shared JWT signing key for all agents (required for cross-agent user JWT validation)
SECRET_KEY=replace_this_with_a_shared_secret_key_min_32_chars
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5-coder:7b
/# Optional model profile routing. If set, this takes precedence over
# DEFAULT_PROVIDER/DEFAULT_MODEL and keeps those values as legacy fallback.
MODEL_PROFILES_PATH=config/models/examples/local-ollama-rtx3080.model_profiles.yaml
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=5m

# Model Defaults
# General tasks remain on OpenAI (already configured in app/runtime config).
# Coding default model:
SGPT_DEFAULT_MODEL=lfm2.5-1.2b-glm-4.7-flash-thinking-i1
CODEX_DEFAULT_MODEL=gpt-5-codex
OPENCODE_DEFAULT_MODEL=opencode/glm-5-free
CODECOMPASS_FTS_ENABLED=0
CODECOMPASS_VECTOR_ENABLED=0
CODECOMPASS_GRAPH_ENABLED=0
CODECOMPASS_RELATION_EXPANSION_ENABLED=0

# CodeCompass runtime domain scope (CCRDS)
# When enabled, a `domain:<id>` value in chat_retrieval_domain_hint is
# resolved against domains.detected.json / domains/<id>/domain.json and
# hard-limits retrieval (and write validation) to the domain's paths.
CODECOMPASS_DOMAIN_SCOPE_ENABLED=0
CODECOMPASS_DOMAIN_ARTIFACT_PATH=artifacts/codecompass/domains.detected.json
CODECOMPASS_DOMAIN_DESCRIPTOR_ROOT=domains
CODECOMPASS_SCOPE_STRICT_MODE=1
CODECOMPASS_SCOPE_ALLOW_RELATION_EXPANSION=0
CODECOMPASS_SCOPE_MAX_EXTERNAL_REFERENCE_CHUNKS=2

# CodeCompass / Worker handoff defaults
# Keep vector retrieval disabled unless an embedding provider is explicitly
# configured through AGENT_CONFIG. The built-in default is offline local_hash.
CODECOMPASS_WORKER_HANDOFF_POLICY_VERSION=v3.0

# Ananta worker architecture full scan
# Explicit full-scan mode is used for architecture diagrams and whole-system
# explanations. Normal short chat/RAG questions continue to use the fast path.
ANANTA_WORKER_FULL_SCAN_ENABLED=1
ANANTA_WORKER_FULL_SCAN_MAX_BATCHES=8
ANANTA_WORKER_FULL_SCAN_FILES_PER_BATCH=3
ANANTA_WORKER_FULL_SCAN_MAX_REF_CHARS=4000
ANANTA_WORKER_FULL_SCAN_SUMMARY_CHARS=12000
ANANTA_WORKER_FULL_SCAN_MAX_TOTAL_REF_COUNT=120

# RAG Route Quotas — max results per retrieval engine per query type
# Reduce on weak hardware (e.g. RAG_ROUTE_QUOTA_CODE_REPO=6)
RAG_ROUTE_QUOTA_CODE_REPO=12
RAG_ROUTE_QUOTA_CODE_SEMANTIC=2
RAG_ROUTE_QUOTA_DOCS_SEMANTIC=4
RAG_ROUTE_QUOTA_DOCS_REPO=2
RAG_ROUTE_QUOTA_FS_AGENTIC=3
RAG_ROUTE_QUOTA_FS_REPO=2
RAG_ROUTE_QUOTA_DEFAULT_REPO=6
RAG_ROUTE_QUOTA_DEFAULT_SEMANTIC=4

# RAG Scan Exclusions — comma-separated directory names to skip during repo scan
# node_modules, .venv, .git and project-workspaces are excluded to avoid
# indexing large dependency trees and internal Claude Code workspace state.
RAG_SCAN_EXCLUDE_DIRS=.git,.venv,venv,myvenv,site-packages,node_modules,__pycache__,.mypy_cache,.claude,project-workspaces,.tox,dist,build,.eggs

# RAG Query Normalization — expands queries for better multilingual retrieval
# RAG_QUERY_NORMALIZE_MODE: off | keyword | llm
#   off     — no expansion, fastest, use when queries are always in English
#   keyword — offline DE↔EN keyword mapping (default, no LLM required)
#   llm     — optional LLM-based translation (reserved, falls back to keyword)
# RAG_QUERY_NORMALIZE_LANG: comma-separated language hints (de,en)
# RAG_QUERY_TRANSLATION_DIRECTIONS: de_to_en | en_to_de | mixed_code_query (comma-separated)
#   de_to_en         — German queries find English code symbols (most useful default)
#   en_to_de         — English queries find German docs/comments/todos
#   mixed_code_query — queries mixing German text with code tokens
RAG_QUERY_NORMALIZE_MODE=keyword
RAG_QUERY_NORMALIZE_LANG=de,en
RAG_QUERY_TRANSLATION_DIRECTIONS=de_to_en,mixed_code_query

# Initial Admin User/Password (used on first start)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=test123
E2E_ADMIN_PASSWORD=test123

# Live test tuning (optional)
RUN_LIVE_LLM_TESTS=0
LIVE_LLM_PROVIDER=ollama
LIVE_LLM_MODEL=ananta-smoke
LIVE_LLM_TIMEOUT_SEC=60
LIVE_LLM_RETRY_ATTEMPTS=1
LIVE_LLM_RETRY_BACKOFF_SEC=0.5
RUN_LIVE_VOXTRAL_TESTS=0
LIVE_VOXTRAL_RUNTIME_URL=http://localhost:8090
RUN_VOICE_DOCKER_SMOKE=0

# Voice runtime defaults
VOICE_PROVIDER=voice-runtime
VOICE_RUNTIME_URL=http://voice-runtime:8090
VOICE_MODEL=voxtral
VOICE_FALLBACK_MODEL=whisper-small
VOICE_MAX_AUDIO_MB=25
VOICE_TIMEOUT_SEC=120
VOICE_DIRECT_CLIENT_ACCESS=false
VOICE_RUNTIME_DEVICE=auto
VOICE_RUNTIME_MODEL_PATH=
VOICE_BACKEND_FALLBACK_ORDER=voxtral,mock
VOICE_ENABLE_STREAMING=false
VOICE_STORE_AUDIO=false
VOICE_TRANSCRIPTION_PIPELINE=simple
VOICE_VAD_BACKEND=mock
VOICE_ASR_BACKEND=mock
VOICE_POSTPROCESS_BACKEND=none
VOICE_CONFIDENCE_RERUN_ENABLED=false
VOICE_CONFIDENCE_THRESHOLD=0.7
VOICE_RERUN_BACKEND=mock
VOICE_RERUN_MAX_SEGMENTS=3
VOICE_DIARIZATION_BACKEND=none
VOICE_GLOSSARY_PATH=
VOICE_VOSK_MODEL_PATH=
VOICE_WHISPER_CPP_BIN=
VOICE_WHISPER_CPP_MODEL_PATH=
VOICE_WHISPER_CPP_EXTRA_ARGS=

# Auth Security Tuning (optional; secure defaults are built-in)
AUTH_RATE_LIMIT_WINDOW_SHORT_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS_SHORT=10
AUTH_RATE_LIMIT_WINDOW_LONG_SECONDS=3600
AUTH_RATE_LIMIT_MAX_ATTEMPTS_LONG=50
AUTH_IP_BAN_DURATION_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_USER_LOCKOUT_THRESHOLD=5
AUTH_USER_LOCKOUT_DURATION_SECONDS=900
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_HISTORY_LIMIT=3
AUTH_MFA_BACKUP_CODE_COUNT=10

# OIDC / Keycloak (optional)
TERMINAL_OIDC_ENABLED=false
TERMINAL_OIDC_ISSUER=http://localhost:8081/realms/ananta
TERMINAL_OIDC_BROWSER_ISSUER=http://localhost:8081/realms/ananta
TERMINAL_OIDC_AUDIENCE=ananta-hub
TERMINAL_OIDC_CLIENT_ID=ananta-hub

# Native SSH (optional)
NATIVE_SSH_ENABLED=false
SSH_CA_BACKEND=none
SSH_CA_STEP_CA_URL=
SSH_CA_STEP_CA_PROVISIONER=ananta-oidc
SSH_CA_STEP_CA_CA_FINGERPRINT=
SSH_CERTIFICATE_VALIDITY_SECONDS_WORKER=3600
SSH_CERTIFICATE_VALIDITY_SECONDS_HUB=900
SSH_BROAD_PRINCIPALS_ALLOWED=false
SSH_TERMINAL_WRAPPER_REQUIRED=true
SSH_AUDIT_ENABLED=true

# Local Keycloak compose overlay (docker-compose.oidc-keycloak.yml)
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_change_me

# Ananta Network Profile (public-ananta | local | offline | custom)
# Default: local (eigene Infrastruktur)
ANANTA_NETWORK_PROFILE=local

# Public Ananta Rendezvous (nur wenn ANANTA_NETWORK_PROFILE=public-ananta)
# WARNUNG: Routing-Metadaten sind für öffentliche Ananta-Server sichtbar.
# Inhalte werden E2E-verschlüsselt. Nicht für vertrauliche Deployments.
ANANTA_PUBLIC_RENDEZVOUS_ENABLED=false
ANANTA_OIDC_ISSUER=https://keycloak.ananta.de/realms/ananta
ANANTA_OIDC_CLIENT_ID=ananta-tui
ANANTA_RENDEZVOUS_URL=https://webrtc.ananta.de
ANANTA_SIGNALING_URL=wss://webrtc.ananta.de/signaling
ANANTA_TURN_URL=turns:webrtc.ananta.de:5349
ANANTA_REQUIRE_E2E_PAYLOAD_ENCRYPTION=true

# TUI E2E (dedizierter Keycloak/Realm Account für Live-Share-Casts)
# Aktiviert Public-OIDC Login für scripts/e2e/record_tui_demo.py (share-session-live-e2e)
# ANANTA_TUI_E2E_USE_PUBLIC_OIDC=true
# ANANTA_TUI_E2E_OIDC_ISSUER=https://keycloak.ananta.de/realms/ananta-e2e
# ANANTA_TUI_E2E_OIDC_CLIENT_ID=ananta-tui
# ANANTA_TUI_E2E_OIDC_CLIENT_SECRET=
# ANANTA_TUI_E2E_OIDC_USERNAME=e2e
# ANANTA_TUI_E2E_OIDC_PASSWORD=<required-secret>
# ANANTA_TUI_E2E_RENDEZVOUS_URL=https://webrtc.ananta.de
# ANANTA_TUI_E2E_SIGNALING_URL=wss://webrtc.ananta.de/signaling
# Optional: bereits erzeugtes Token direkt setzen (ohne Passwort-Grant)
# ANANTA_TUI_E2E_OIDC_TOKEN=

# Device Key Directory (default: ~/.config/ananta/device-keys)
# ANANTA_DEVICE_KEY_DIR=

# Public Rendezvous Service (docker-compose.public-rendezvous.yml)
# TURN_SHARED_SECRET muss identisch zu coturn --static-auth-secret sein.
# Mit `openssl rand -hex 32` generieren.
TURN_SHARED_SECRET=replace_with_32_random_hex_bytes
TURN_URLS=turn:webrtc.ananta.de:3478
TURN_TTL_SECONDS=3600
SESSION_MAX_DURATION_SECONDS=3600
RENDEZVOUS_DB_PATH=/var/lib/ananta/rendezvous.db
RENDEZVOUS_DB_TIMEOUT_SECONDS=5.0
RENDEZVOUS_LOG_LEVEL=INFO
# Public VM: externe IP / interne IP für Oracle-Cloud-NAT
PUBLIC_TURN_EXTERNAL_IP=79.76.105.53/10.0.1.233
PUBLIC_KEYCLOAK_HOSTNAME=keycloak.ananta.de
PUBLIC_WEBRTC_HOSTNAME=webrtc.ananta.de

# ─── Operator TUI — AI-Chat / AI-Snake ─────────────────────────────────────
# Most chat settings are also exposed in the TUI under "AI-Snake Config"
# (Ctrl+A). Values set here serve as defaults; values persisted by the TUI
# into user.json take precedence and are mirrored to os.environ on TUI start.
# Use the .env for multi-line strings (e.g. system prompt) that the TUI
# single-line input cannot carry.

# Chat system prompt — must contain "{context}" (falls back to default).
# Multi-line is allowed here. The TUI exposes a single-line editor for
# shorter prompts.
# ANANTA_TUI_CHAT_SYSTEM_PROMPT="Du bist ein hilfreicher Assistent für {project_name}. Kontext:\n{context}\n{depth_instruction}"

# Chat streaming on/off (default: 1)
# ANANTA_TUI_CHAT_STREAMING=1

# Chat RAG/embedding API toggle and model.
# When AN, the chat pipeline calls a dedicated embeddings endpoint
# (LMStudio /v1/embeddings or your OpenAI-compatible server) instead of
# falling back to CodeCompass heuristics. Required for large codebases
# where TF-IDF chunking misses semantically related files.
# ANANTA_TUI_CHAT_USE_EMBEDDING_API=0
# ANANTA_TUI_CHAT_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# ANANTA_TUI_CHAT_EMBEDDING_API_MAX_RECORDS=64

# Existing ANANTA_TUI_SNAKE_AI_* knobs (unchanged — full list):
# ANANTA_TUI_SNAKE_AI_TIMEOUT, ANANTA_TUI_SNAKE_AI_REFRESH,
# ANANTA_TUI_SNAKE_AI_BACKEND, ANANTA_TUI_SNAKE_AI_PROMPT_TEMPLATE,
# ANANTA_TUI_SNAKE_AI_ASYNC, ANANTA_TUI_SNAKE_AI_TRAINING,
# ANANTA_TUI_SNAKE_AI_WORKER_*, ANANTA_TUI_SNAKE_TUTORIAL_AI,
# ANANTA_TUI_SNAKE_RAG_TOP_K, ANANTA_TUI_SNAKE_RAG_MAX_RECORDS_PER_FILE
# See docs/operator-tui.md for the full reference.

# ─── Workflow Layer (WFG-003) ─────────────────────────────────────────────
# WFG-001 introduced an optional 'workflow' block in seed_blueprint_catalog.v1
# that describes a deterministic DAG of steps and gate reviews. The env
# variables below are the deployment-wide overrides documented in
# docs/decisions/ADR-workflow-gates-blueprint-contract.md.
#
# ANANTA_WORKFLOW_MODE: off | auto | enforce (default: auto)
#   off     - workflow block is ignored even if a blueprint declares it
#             (operator-level kill switch; WFG-021 backward-compat path)
#   auto    - workflow block is respected when validated
#   enforce - workflow block is respected AND the planner rejects malformed
#             workflows at materialization time (belt-and-braces with the
#             catalog normalizer)
# ANANTA_WORKFLOW_DEFAULT_GATE: block | skip | manual (default: block)
#   block  - default gate failure halts downstream steps
#   skip   - downstream steps are marked skipped
#   manual - human approval is raised via the operator TUI
# ANANTA_WORKFLOW_GATE_TIMEOUT (default: 86400 = 24h)
#   How long a gate can stay pending before the queue surfaces it as 'stale'
#   (WFG-013). 0 disables the stale check.
# ANANTA_WORKFLOW_AUDIT_ENABLED: 0|1 (default: 1)
#   Persist workflow-handoff events (WFG-015).
# ANANTA_WORKFLOW_ARTIFACT_FLOW: 0|1 (default: 1)
#   Enforce the produces/consumes DAG between steps (WFG-016).
#ANANTA_WORKFLOW_MODE=auto
#ANANTA_WORKFLOW_DEFAULT_GATE=block
#ANANTA_WORKFLOW_GATE_TIMEOUT=86400
#ANANTA_WORKFLOW_AUDIT_ENABLED=1
#ANANTA_WORKFLOW_ARTIFACT_FLOW=1
