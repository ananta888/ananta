# Docker Compose environment variables
# Copy this file to .env and adjust as needed

# Cross-platform path resolution for Git Bash / MSYS on Windows
# Set to 1 if you encounter 'invalid volume specification' errors in Git Bash
COMPOSE_CONVERT_WINDOWS_PATHS=0

# Port Configuration
HUB_PORT=5000
ALPHA_PORT=5001
BETA_PORT=5002
GAMMA_PORT=5003
DELTA_PORT=5004
LMSTUDIO_PROXY_PORT=12340
FRONTEND_PORT=4200
POSTGRES_PORT=5432
REDIS_PORT=6379
HTTP_PORT=80
HTTPS_PORT=443
LOKI_PORT=3100
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# Database Configuration
# GENERATE NEW PASSWORDS FOR PRODUCTION!
POSTGRES_USER=ananta
POSTGRES_PASSWORD=replace_this_with_a_secure_password_123!
POSTGRES_DB=ananta

# Grafana Configuration
GRAFANA_PASSWORD=replace_this_with_a_secure_password_456!

# Service URLs
LMSTUDIO_URL=http://192.168.56.1:1234/v1
OLLAMA_URL=http://host.docker.internal:11434/api/generate
LMSTUDIO_API_MODE=chat
E2E_OLLAMA_URL=http://host.docker.internal:11434/api/generate
E2E_LMSTUDIO_URL=http://host.docker.internal:1234/v1
OLLAMA_VULKAN=1
OLLAMA_WSL_LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64
OLLAMA_WSL_VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/dzn_icd.json
COMPOSE_OLLAMA_URL=http://ollama:11434/api/generate
COMPOSE_LMSTUDIO_URL=http://192.168.56.1:1234/v1
COMPOSE_DEFAULT_PROVIDER=ollama
COMPOSE_DEFAULT_MODEL=qwen2.5-coder:7b
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=WARNING
AUTH_TEST_ENDPOINTS_ENABLED=0
HUB_CAN_BE_WORKER=0

# AI Agent Configuration
# IMPORTANT: Change these tokens for production use!
# They are used for inter-agent communication security.
AGENT_TOKEN_HUB=generate_a_random_token_for_hub
AGENT_TOKEN_ALPHA=generate_a_random_token_for_alpha
AGENT_TOKEN_BETA=generate_a_random_token_for_beta
AGENT_TOKEN_GAMMA=generate_a_random_token_for_gamma
AGENT_TOKEN_DELTA=generate_a_random_token_for_delta
# Shared JWT signing key for all agents (required for cross-agent user JWT validation)
SECRET_KEY=replace_this_with_a_shared_secret_key_min_32_chars
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b

# Model Defaults
# General tasks remain on OpenAI (already configured in app/runtime config).
# Coding default model:
SGPT_DEFAULT_MODEL=lfm2.5-1.2b-glm-4.7-flash-thinking-i1
CODEX_DEFAULT_MODEL=gpt-5-codex
OPENCODE_DEFAULT_MODEL=opencode/glm-5-free

# Initial Admin User/Password (used on first start)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=replace_this_with_a_secure_admin_password_789!
E2E_ADMIN_PASSWORD=AnantaAdminPassword123!

# Live test tuning (optional)
RUN_LIVE_LLM_TESTS=0
LIVE_LLM_PROVIDER=ollama
LIVE_LLM_MODEL=ananta-smoke
LIVE_LLM_TIMEOUT_SEC=60
LIVE_LLM_RETRY_ATTEMPTS=1
LIVE_LLM_RETRY_BACKOFF_SEC=0.5

# Auth Security Tuning (optional; secure defaults are built-in)
AUTH_RATE_LIMIT_WINDOW_SHORT_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS_SHORT=10
AUTH_RATE_LIMIT_WINDOW_LONG_SECONDS=3600
AUTH_RATE_LIMIT_MAX_ATTEMPTS_LONG=50
AUTH_IP_BAN_DURATION_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_USER_LOCKOUT_THRESHOLD=5
AUTH_USER_LOCKOUT_DURATION_SECONDS=900
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_HISTORY_LIMIT=3
AUTH_MFA_BACKUP_CODE_COUNT=10
