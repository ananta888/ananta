# Docker Compose environment variables
# Copy this file to .env and adjust as needed

# Cross-platform path resolution for Git Bash / MSYS on Windows
# Set to 1 if you encounter 'invalid volume specification' errors in Git Bash
COMPOSE_CONVERT_WINDOWS_PATHS=0

# Port Configuration
HUB_PORT=5000
ALPHA_PORT=5001
BETA_PORT=5002
GAMMA_PORT=5003
DELTA_PORT=5004
LMSTUDIO_PROXY_PORT=12340
FRONTEND_PORT=4200
POSTGRES_PORT=5432
REDIS_PORT=6379
HTTP_PORT=80
HTTPS_PORT=443
LOKI_PORT=3100
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# Database Configuration
# GENERATE NEW PASSWORDS FOR PRODUCTION!
POSTGRES_USER=ananta
POSTGRES_PASSWORD=replace_this_with_a_secure_password_123!
POSTGRES_DB=ananta

# Grafana Configuration
GRAFANA_PASSWORD=replace_this_with_a_secure_password_456!

# Service URLs
LMSTUDIO_URL=http://192.168.56.1:1234/v1
OLLAMA_URL=http://host.docker.internal:11434/api/generate
LMSTUDIO_API_MODE=chat
E2E_OLLAMA_URL=http://host.docker.internal:11434/api/generate
E2E_LMSTUDIO_URL=http://host.docker.internal:1234/v1
OLLAMA_VULKAN=1
OLLAMA_WSL_LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64
OLLAMA_WSL_VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/dzn_icd.json
COMPOSE_OLLAMA_URL=http://ollama:11434/api/generate
COMPOSE_LMSTUDIO_URL=http://192.168.56.1:1234/v1
COMPOSE_DEFAULT_PROVIDER=ollama
COMPOSE_DEFAULT_MODEL=qwen2.5-coder:7b
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=WARNING
AUTH_TEST_ENDPOINTS_ENABLED=0
HUB_CAN_BE_WORKER=0

# AI Agent Configuration
# IMPORTANT: Change these tokens for production use!
# They are used for inter-agent communication security.
AGENT_TOKEN_HUB=generate_a_random_token_for_hub
AGENT_TOKEN_ALPHA=generate_a_random_token_for_alpha
AGENT_TOKEN_BETA=generate_a_random_token_for_beta
AGENT_TOKEN_GAMMA=generate_a_random_token_for_gamma
AGENT_TOKEN_DELTA=generate_a_random_token_for_delta
# Shared JWT signing key for all agents (required for cross-agent user JWT validation)
SECRET_KEY=replace_this_with_a_shared_secret_key_min_32_chars
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=5m

# Model Defaults
# General tasks remain on OpenAI (already configured in app/runtime config).
# Coding default model:
SGPT_DEFAULT_MODEL=lfm2.5-1.2b-glm-4.7-flash-thinking-i1
CODEX_DEFAULT_MODEL=gpt-5-codex
OPENCODE_DEFAULT_MODEL=opencode/glm-5-free
CODECOMPASS_FTS_ENABLED=0
CODECOMPASS_VECTOR_ENABLED=0
CODECOMPASS_GRAPH_ENABLED=0
CODECOMPASS_RELATION_EXPANSION_ENABLED=0

# Initial Admin User/Password (used on first start)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=test123
E2E_ADMIN_PASSWORD=test123

# Live test tuning (optional)
RUN_LIVE_LLM_TESTS=0
LIVE_LLM_PROVIDER=ollama
LIVE_LLM_MODEL=ananta-smoke
LIVE_LLM_TIMEOUT_SEC=60
LIVE_LLM_RETRY_ATTEMPTS=1
LIVE_LLM_RETRY_BACKOFF_SEC=0.5
RUN_LIVE_VOXTRAL_TESTS=0
LIVE_VOXTRAL_RUNTIME_URL=http://localhost:8090
RUN_VOICE_DOCKER_SMOKE=0

# Voice runtime defaults
VOICE_PROVIDER=voice-runtime
VOICE_RUNTIME_URL=http://voice-runtime:8090
VOICE_MODEL=voxtral
VOICE_FALLBACK_MODEL=whisper-small
VOICE_MAX_AUDIO_MB=25
VOICE_TIMEOUT_SEC=120
VOICE_DIRECT_CLIENT_ACCESS=false
VOICE_RUNTIME_DEVICE=auto
VOICE_RUNTIME_MODEL_PATH=
VOICE_BACKEND_FALLBACK_ORDER=voxtral,mock
VOICE_ENABLE_STREAMING=false
VOICE_STORE_AUDIO=false

# Auth Security Tuning (optional; secure defaults are built-in)
AUTH_RATE_LIMIT_WINDOW_SHORT_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS_SHORT=10
AUTH_RATE_LIMIT_WINDOW_LONG_SECONDS=3600
AUTH_RATE_LIMIT_MAX_ATTEMPTS_LONG=50
AUTH_IP_BAN_DURATION_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_USER_LOCKOUT_THRESHOLD=5
AUTH_USER_LOCKOUT_DURATION_SECONDS=900
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_HISTORY_LIMIT=3
AUTH_MFA_BACKUP_CODE_COUNT=10

# OIDC / Keycloak (optional)
TERMINAL_OIDC_ENABLED=false
TERMINAL_OIDC_ISSUER=http://localhost:8081/realms/ananta
TERMINAL_OIDC_BROWSER_ISSUER=http://localhost:8081/realms/ananta
TERMINAL_OIDC_AUDIENCE=ananta-hub
TERMINAL_OIDC_CLIENT_ID=ananta-hub

# Native SSH (optional)
NATIVE_SSH_ENABLED=false
SSH_CA_BACKEND=none
SSH_CA_STEP_CA_URL=
SSH_CA_STEP_CA_PROVISIONER=ananta-oidc
SSH_CA_STEP_CA_CA_FINGERPRINT=
SSH_CERTIFICATE_VALIDITY_SECONDS_WORKER=3600
SSH_CERTIFICATE_VALIDITY_SECONDS_HUB=900
SSH_BROAD_PRINCIPALS_ALLOWED=false
SSH_TERMINAL_WRAPPER_REQUIRED=true
SSH_AUDIT_ENABLED=true

# Local Keycloak compose overlay (docker-compose.oidc-keycloak.yml)
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_change_me

# Ananta Network Profile (public-ananta | local | offline | custom)
# Default: local (eigene Infrastruktur)
ANANTA_NETWORK_PROFILE=local

# Public Ananta Rendezvous (nur wenn ANANTA_NETWORK_PROFILE=public-ananta)
# WARNUNG: Routing-Metadaten sind für öffentliche Ananta-Server sichtbar.
# Inhalte werden E2E-verschlüsselt. Nicht für vertrauliche Deployments.
ANANTA_PUBLIC_RENDEZVOUS_ENABLED=false
ANANTA_OIDC_ISSUER=https://keycloak.ananta.de/realms/ananta
ANANTA_OIDC_CLIENT_ID=ananta-tui
ANANTA_RENDEZVOUS_URL=https://webrtc.ananta.de
ANANTA_SIGNALING_URL=wss://webrtc.ananta.de/signaling
ANANTA_TURN_URL=turns:webrtc.ananta.de:5349
ANANTA_REQUIRE_E2E_PAYLOAD_ENCRYPTION=true

# Device Key Directory (default: ~/.config/ananta/device-keys)
# ANANTA_DEVICE_KEY_DIR=

# Public Rendezvous Service (docker-compose.public-rendezvous.yml)
# TURN_SHARED_SECRET muss identisch zu coturn --static-auth-secret sein.
# Mit `openssl rand -hex 32` generieren.
TURN_SHARED_SECRET=replace_with_32_random_hex_bytes
TURN_URLS=turn:webrtc.ananta.de:3478
TURN_TTL_SECONDS=3600
SESSION_MAX_DURATION_SECONDS=3600
RENDEZVOUS_LOG_LEVEL=INFO
# Public VM: externe IP / interne IP für Oracle-Cloud-NAT
PUBLIC_TURN_EXTERNAL_IP=79.76.105.53/10.0.1.233
PUBLIC_KEYCLOAK_HOSTNAME=keycloak.ananta.de
PUBLIC_WEBRTC_HOSTNAME=webrtc.ananta.de
