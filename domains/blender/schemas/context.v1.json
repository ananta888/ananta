{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.local/domains/blender/schemas/context.v1.json",
  "title": "Blender Context v1",
  "type": "object",
  "required": ["schema", "scene_name", "selection", "blender_version"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "blender_context.v1"
    },
    "scene_name": {
      "type": "string",
      "minLength": 1
    },
    "selection": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blender_version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
