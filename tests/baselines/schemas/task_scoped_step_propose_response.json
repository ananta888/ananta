          "title": "Sources",
          "type": "array"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "trace": {
          "additionalProperties": true,
          "title": "Trace",
          "type": "object"
        },
        "verification": {
          "additionalProperties": true,
          "title": "Verification",
          "type": "object"
        }
      },
      "required": [
        "summary",
        "report_markdown"
      ],
      "title": "ResearchArtifact",
      "type": "object"
    },
    "ResearchContextSummaryContract": {
      "properties": {
        "artifact_ids": {
          "items": {
            "type": "string"
