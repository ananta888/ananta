        "kind": {
          "default": "research_report",
          "title": "Kind",
          "type": "string"
        },
        "report_markdown": {
          "title": "Report Markdown",
          "type": "string"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/ResearchSource"
