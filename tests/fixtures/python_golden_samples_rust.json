{
  "schema": "python_to_rust_golden_samples.v1",
  "target_language": "rust",
  "samples": [
    {
      "id": "pyjr-rust-001",
      "description": "Simple dataclass → Rust struct with owned fields",
      "source_python": "@dataclass\nclass User:\n    name: str\n    age: int",
      "source_kind": "dataclass",
      "expected_rust_kind": "struct",
      "expected_fields": ["name", "age"],
      "expected_types": {"name": "String", "age": "i64"},
      "expected_warnings": [],
      "expected_verifier_status": "verified",
      "rules": ["pyjr.dataclass_to_rust_struct.v1"]
    },
    {
      "id": "pyjr-rust-002",
      "description": "Frozen dataclass → Rust struct with PartialEq",
      "source_python": "@dataclass(frozen=True)\nclass Point:\n    x: float\n    y: float",
      "source_kind": "frozen_dataclass",
      "expected_rust_kind": "struct",
      "expected_contains": ["PartialEq", "pub struct Point"],
      "expected_fields": ["x", "y"],
      "expected_types": {"x": "f64", "y": "f64"},
      "expected_warnings": [],
      "expected_verifier_status": "verified",
      "rules": ["pyjr.dataclass_to_rust_struct.v1"]
    },
