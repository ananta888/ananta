# Ananta Environment Template
# Kopiere diese Datei nach .env und fülle die Werte aus.

# --- Datenbank (PostgreSQL) ---
POSTGRES_USER=ananta
POSTGRES_PASSWORD=
POSTGRES_DB=ananta
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Monitoring (Grafana) ---
GRAFANA_PORT=3000
GRAFANA_PASSWORD=
LOKI_PORT=3100
PROMETHEUS_PORT=9090

# --- Frontend & Proxy ---
HTTP_PORT=80
HTTPS_PORT=443
FRONTEND_PORT=4200

# --- Sonstiges ---
RUN_LIVE_LLM_TESTS=0
OLLAMA_VULKAN=1
OLLAMA_WSL_LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64
OLLAMA_WSL_VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/dzn_icd.json
COMPOSE_OLLAMA_URL=http://ollama:11434/api/generate
COMPOSE_LMSTUDIO_URL=http://192.168.56.1:1234/v1
COMPOSE_DEFAULT_PROVIDER=ollama
COMPOSE_DEFAULT_MODEL=llama3

# --- Modell-Defaults ---
# Allgemeine Aufgaben: OpenAI (bestehende Runtime-Konfiguration bleibt bestehen)
# Coding-Standardmodell:
SGPT_DEFAULT_MODEL=lfm2.5-1.2b-glm-4.7-flash-thinking-i1

# --- Auth Security Tuning (optional) ---
AUTH_RATE_LIMIT_WINDOW_SHORT_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS_SHORT=10
AUTH_RATE_LIMIT_WINDOW_LONG_SECONDS=3600
AUTH_RATE_LIMIT_MAX_ATTEMPTS_LONG=50
AUTH_IP_BAN_DURATION_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_USER_LOCKOUT_THRESHOLD=5
AUTH_USER_LOCKOUT_DURATION_SECONDS=900
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_HISTORY_LIMIT=3
AUTH_MFA_BACKUP_CODE_COUNT=10
