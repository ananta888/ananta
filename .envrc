# Ananta local dev — docker-compose defaults
# Wird automatisch geladen wenn du ins Repo-Verzeichnis wechselst.
# Werte kommen aus .env (docker-compose Stack).

export ANANTA_BASE_URL=http://localhost:5000
export ANANTA_USER=admin
export ANANTA_PASSWORD=test123

# venv automatisch aktivieren wenn vorhanden
if [ -f "venv/bin/activate" ]; then
  source venv/bin/activate
fi
