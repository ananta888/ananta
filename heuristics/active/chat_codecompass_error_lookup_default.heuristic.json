{
  "heuristic_id": "chat_codecompass_error_lookup_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "chat_codecompass",
  "description": "Surface error/exception context from source refs when query contains error keywords. Never fabricates error causes.",
  "deterministic": true,
  "safety_class": "readonly",
  "capabilities": ["read_local_context", "read_source_refs", "read_artifact_refs"],
  "ttl_policy": {
    "default_seconds": 15.0,
    "min_seconds": 10.0,
    "max_seconds": 20.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.chat_codecompass.error_lookup",
      "class": "ErrorLookupStrategy",
      "expected_inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
      "expected_outputs": ["show_context_summary", "ask_scope", "no_action"]
    },
    "triggers": [
      {"query_contains_any": ["error", "exception", "stacktrace", "fail", "crash"]},
      {"query_contains_any": ["caused by", "npe", "nullpointer", "classnotfound"]}
    ],
    "action": {
      "kind": "show_context_summary",
      "fallback": "ask_scope"
    }
  },
  "inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
  "outputs": ["context_summary"],
  "parameters": {
    "min_score": 0.15
  },
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic"}
  ]
}
