{
  "heuristic_id": "chat_codecompass_symbol_lookup_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "chat_codecompass",
  "description": "Look up a code symbol in CodeCompass source refs when the query contains class/method/type tokens. Opens most relevant source ref.",
  "deterministic": true,
  "safety_class": "readonly",
  "capabilities": ["read_local_context", "read_source_refs"],
  "ttl_policy": {
    "default_seconds": 15.0,
    "min_seconds": 10.0,
    "max_seconds": 20.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.chat_codecompass.symbol_lookup",
      "class": "SymbolLookupStrategy",
      "expected_inputs": ["query", "allowed_source_scopes"],
      "expected_outputs": ["open_source_ref", "no_action"]
    },
    "triggers": [
      {"query_contains_any": ["class", "method", "function", "interface", "import"]},
      {"query_contains_any": ["def ", "extends", "implements", "override"]}
    ],
    "action": {
      "kind": "open_source_ref",
      "fallback": "no_action"
    }
  },
  "inputs": ["query", "allowed_source_scopes"],
  "outputs": ["source_ref"],
  "parameters": {
    "min_score": 0.2
  },
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic"}
  ]
}
