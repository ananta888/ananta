{
  "heuristic_id": "helpcenter_github_failure_source_refs_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "helpcenter",
  "description": "Look up GitHub failure context (PR, issue, commit, workflow) from CodeCompass source refs.",
  "deterministic": true,
  "safety_class": "readonly",
  "capabilities": ["read_local_context", "read_source_refs", "read_artifact_refs"],
  "ttl_policy": {
    "default_seconds": 15.0,
    "min_seconds": 10.0,
    "max_seconds": 20.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.helpcenter.github_failure_refs",
      "class": "GithubFailureSourceRefsStrategy",
      "expected_inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
      "expected_outputs": ["open_source_ref", "ask_scope", "no_action"]
    },
    "triggers": [
      {"query_contains_any": ["pr", "pull request", "issue", "commit", "branch"]},
      {"query_contains_any": ["github", "workflow", "action", "check run"]}
    ],
    "action": {
      "kind": "open_source_ref",
      "fallback": "ask_scope"
    }
  },
  "inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
  "outputs": ["source_ref"],
  "parameters": {"min_score": 0.1},
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic"}
  ]
}
