{
  "heuristic_id": "planning_related_todo_merge_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "planning",
  "description": "Identify related TODOs that could be merged or consolidated. Never merges tasks autonomously.",
  "deterministic": true,
  "safety_class": "readonly",
  "capabilities": ["read_local_context", "read_source_refs"],
  "ttl_policy": {
    "default_seconds": 15.0,
    "min_seconds": 10.0,
    "max_seconds": 20.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.planning.related_todo_merge",
      "class": "RelatedTodoMergeStrategy",
      "expected_inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
      "expected_outputs": ["show_context_summary", "ask_scope", "no_action"]
    },
    "triggers": [
      {"query_contains_any": ["merge", "combine", "consolidate", "group", "overlap"]},
      {"query_contains_any": ["duplicate", "related", "similar task", "deduplicate"]}
    ],
    "action": {
      "kind": "show_context_summary",
      "fallback": "ask_scope"
    }
  },
  "inputs": ["query", "allowed_source_scopes", "selected_artifacts"],
  "outputs": ["context_summary"],
  "parameters": {"min_score": 0.1},
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic"}
  ]
}
