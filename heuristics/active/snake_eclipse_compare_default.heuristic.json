{
  "heuristic_id": "snake_eclipse_compare_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "snake_eclipse",
  "description": "Follow diff direction in Eclipse Compare/Git compare view. Naturally follows left-to-right diff reading direction.",
  "deterministic": true,
  "safety_class": "ui_motion_only",
  "capabilities": ["read_local_context"],
  "ttl_policy": {
    "default_seconds": 7.0,
    "min_seconds": 5.0,
    "max_seconds": 10.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.snake_eclipse.compare",
      "class": "EclipseCompareStrategy",
      "expected_inputs": ["active_panel"],
      "expected_outputs": ["follow", "fallback"]
    },
    "triggers": [
      {"active_panel_is": "compare"},
      {"active_panel_is": "diff"},
      {"active_panel_is": "git_compare"},
      {"event_type_is": "compare_opened"}
    ],
    "action": {
      "kind": "follow_with_distance",
      "distance": 3,
      "fallback": "lurk_near"
    }
  },
  "inputs": ["active_panel"],
  "outputs": ["motion_vector"],
  "parameters": {
    "right_side": true
  },
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic — Eclipse compare view"}
  ]
}
