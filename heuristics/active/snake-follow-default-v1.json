  "inputs": ["cursor_position", "board_dimensions", "follow_state"],
  "outputs": ["suggested_motion", "follow_mode"],
  "parameters": {
    "follow_distance": 4,
    "linger_distance": 6,
    "speed_factor": 0.45
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Initialer Starter aus ai_snake_follow.py"}
  ]
}
