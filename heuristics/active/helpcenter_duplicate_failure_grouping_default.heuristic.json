{
  "heuristic_id": "helpcenter_duplicate_failure_grouping_default",
  "version": "1.0.0",
  "status": "active",
  "domain": "helpcenter",
  "description": "Group similar or recurring failures by surfacing existing known-issue refs. Never creates groupings autonomously.",
  "deterministic": true,
  "safety_class": "readonly",
  "capabilities": ["read_local_context", "read_source_refs"],
  "ttl_policy": {
    "default_seconds": 15.0,
    "min_seconds": 10.0,
    "max_seconds": 20.0
  },
  "runtime": {
    "mode": "python_strategy",
    "python_strategy": {
      "module": "agent.heuristics.strategies.helpcenter.duplicate_grouping",
      "class": "DuplicateFailureGroupingStrategy",
      "expected_inputs": ["query", "allowed_source_scopes"],
      "expected_outputs": ["show_context_summary", "ask_scope", "no_action"]
    },
    "triggers": [
      {"query_contains_any": ["duplicate", "same", "similar", "again", "already"]},
      {"query_contains_any": ["flaky", "intermittent", "recur", "known issue"]}
    ],
    "action": {
      "kind": "show_context_summary",
      "fallback": "ask_scope"
    }
  },
  "inputs": ["query", "allowed_source_scopes"],
  "outputs": ["context_summary"],
  "parameters": {"min_score": 0.1},
  "provenance": {
    "created_by": "bootstrap",
    "normalized_from": "json",
    "schema_version": "heuristic_definition.v1"
  },
  "changelog": [
    {"version": "1.0.0", "date": "2026-05-27", "note": "Bootstrap heuristic"}
  ]
}
