FROM python:3.11-slim

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    NPM_CONFIG_FUND=false

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    net-tools \
    iputils-ping \
    traceroute \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

RUN npm i -g opencode-ai && npm cache clean --force

WORKDIR /app

COPY requirements.txt ./
COPY rag-helper/requirements.txt ./rag-helper/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt -r rag-helper/requirements.txt

COPY . .

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    FLASK_DEBUG=0

CMD ["sh", "-c", "alembic upgrade head && exec python -m agent.ai_agent"]
