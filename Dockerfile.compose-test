FROM python:3.11-slim

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt ./
COPY rag-helper/requirements.txt ./rag-helper/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt -r rag-helper/requirements.txt

COPY . .

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    FLASK_DEBUG=0

CMD ["sh", "-c", "alembic upgrade head && exec python -m agent.ai_agent"]
