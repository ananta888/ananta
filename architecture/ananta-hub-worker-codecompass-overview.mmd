%% Ananta architecture - simple explanation for demos
%% Der Hub koordiniert. Worker fuehren aus. Agents/Tools laufen in Workern.
%% CodeCompass liefert den Projektkontext.

flowchart TD
    U["User / UI / CLI"] --> H["Hub\nKoordinator"]

    H --> W1["Worker 1"]
    H --> W2["Worker 2"]
    H --> W3["Worker 3"]

    W1 --> A1["Agent / Tool\nz.B. OpenCode"]
    W2 --> A2["Agent / Tool\nz.B. Hermes"]
    W3 --> A3["Agent / Tool\nz.B. Ananta-Worker"]

    H <--> CC["CodeCompass\nContextManager"]
    CC --> SRC["Projektcode\nDateien · Symbole · Artefakte · RAG"]

    A1 --> H
    A2 --> H
    A3 --> H

    H -.-> RULE["Standardpfad:\nUser -> Hub -> Worker -> Agent/Tool\nkein Agent->Agent\nkein Worker->Worker"]
