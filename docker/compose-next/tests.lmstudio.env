# ── Pflicht-Variablen ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ananta_password
INITIAL_ADMIN_PASSWORD=test123

# ── Datenbank / Redis ─────────────────────────────────────────────────────────
POSTGRES_USER=ananta
POSTGRES_DB=ananta
REDIS_URL=redis://redis:6379/0

# ── Auth / Security ───────────────────────────────────────────────────────────
INITIAL_ADMIN_USER=admin
SECRET_KEY=ananta-dev-shared-secret-change-me
AUTH_TEST_ENDPOINTS_ENABLED=1

# ── LLM Provider ─────────────────────────────────────────────────────────────
LIVE_LLM_PROVIDER=lmstudio
LIVE_LLM_MODEL=auto
LIVE_LLM_TIMEOUT_SEC=120
LIVE_LLM_RETRY_ATTEMPTS=2
LIVE_LLM_RETRY_BACKOFF_SEC=1.0
LMSTUDIO_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_MODE=chat
OPENAI_URL=
OPENAI_API_KEY=

# ── Timeouts / Profil ─────────────────────────────────────────────────────────
HTTP_TIMEOUT=300
COMMAND_TIMEOUT=300
ANANTA_RUNTIME_PROFILE=compose-safe

# ── Ports (nur für Hub/Frontend-Healthcheck intern, keine Exposition) ─────────
HUB_PORT=5000
FRONTEND_PORT=4200

# ── Agent-Tokens (optional für Tests) ────────────────────────────────────────
AGENT_TOKEN_HUB=
AGENT_TOKEN_ALPHA=
AGENT_TOKEN_BETA=

# ── E2E Timeouts ─────────────────────────────────────────────────────────────
E2E_LIVE_LLM_TIMEOUT_MS=300000
E2E_LLM_API_TIMEOUT_MS=300000
