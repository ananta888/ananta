{
  "schema": "ananta.agent_profile_map.v2",
  "description": "Maps standard planning/task paths to AGENTS.md profiles. Runtime-active from APRL implementation: AgentProfileService uses this as loader input.",
  "global_profile": "AGENTS.md",
  "schema_fields": {
    "activation": "list[str] — task_kind values, template_id substrings, or keywords that trigger this profile",
    "agents_file": "str — path relative to repo root; must exist and stay within the repo",
    "primary_role": "str — role identifier used in diagnostics and applied_layers",
    "allowed_task_kinds": "list[str] — task_kind values explicitly mapped to this profile",
    "code_change_policy": "enum: via_hub_task_worker | direct_workspace | none",
    "context_policy_hint": "enum: explain_navigate | implement | analyse | diagnose | plan_only"
  },
  "profiles": {
