  ],
  "references": [
    "docs/security/rag-artifact-release-policy.md",
    "docs/security/context-release-gates.md"
  ],
  "lessons": [
    {"id": "chunk-grant-binding", "title": "Chunk-Metadaten und Grant-Bezug", "type": "lesson"},
    {"id": "release-gate-order", "title": "Release-Gate vor Prompt-Erzeugung", "type": "lesson"}
  ],
  "exercise": {
    "id": "route-chunks-by-runtime",
    "title": "Chunks den erlaubten Zielruntimes zuordnen",
