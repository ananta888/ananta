    {"id": "review-checklists", "title": "Review-Checklisten fuer Task-Ketten", "type": "lesson"}
  ],
  "exercise": {
    "id": "build-review-checklist",
    "title": "Review-Checkliste fuer eine sensitive Task-Kette erstellen",
