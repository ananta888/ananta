{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.dev/schemas/contracts/langgraph-graph-descriptor.v1.1.json",
  "title": "LangGraphGraphDescriptor v1.1",
  "description": "Additive extension of v1.0 (LCG-066). Adds subgraph node kind, condition objects on edges, and model_provider_ref. All v1.0 descriptors validate against this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "graph_id", "nodes", "edges", "entrypoint", "stop_conditions"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["langgraph-graph-descriptor.v1", "langgraph-graph-descriptor.v1.1"],
      "description": "Both v1 and v1.1 marker values are accepted — no breaking change."
    },
    "graph_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "default": "1.1" },
    "model_provider_ref": {
      "type": "string",
      "description": "v1.1: explicit provider ref (e.g. 'ollama.llama3.1'). Overrides per-node defaults.",
      "default": "local.default"
    },
    "entrypoint": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["llm", "tool", "human_gate", "router", "artifact_writer", "retriever", "end", "subgraph"]
          },
          "tool_ref": { "type": "string" },
          "retriever_ref": {
            "type": "string",
            "enum": ["codecompass", null],
            "description": "v1.1: retriever node source. Only 'codecompass' allowed."
          },
          "artifact_type": {
            "type": "string",
            "description": "v1.1: for artifact_writer nodes — the artifact kind to emit.",
            "default": "report"
          },
          "subgraph_ref": {
            "type": "string",
            "description": "v1.1: for subgraph nodes — key into payload.subgraph_descriptors."
          },
          "human_gate": { "type": "boolean", "default": false },
          "description": { "type": "string" },
          "metadata": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "condition": {
            "description": "v1.1: conditional edge. Can be a string (on_stop_reason match) or a dict with on_stop_reason / on_state_key+on_state_value. Unconditional edges have no condition field.",
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "on_stop_reason": { "type": "string" },
                  "on_state_key": { "type": "string" },
                  "on_state_value": { "type": "string" }
                },
                "additionalProperties": false
              }
            ]
          },
          "is_back_edge": { "type": "boolean", "default": false }
        }
      }
    },
    "stop_conditions": {
      "type": "object",
      "required": ["max_iterations"],
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 1 },
        "stop_nodes": { "type": "array", "items": { "type": "string" } },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "checkpoint_policy": {
      "type": "string",
      "enum": ["local_ephemeral", "local_ephemeral_or_hub_owned", "hub_owned", "none"]
    },
    "human_gates": {
      "type": "array",
      "description": "Node IDs that require human approval before continuation.",
      "items": { "type": "string" }
    },
    "artifact_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "artifact_type"],
        "properties": {
          "name": { "type": "string" },
          "artifact_type": { "type": "string" },
          "produced_by_node": { "type": "string" }
        }
      }
    },
    "policies": {
      "type": "object",
      "properties": {
        "external_calls_allowed": { "type": "boolean", "default": false },
        "artifact_first": { "type": "boolean", "default": true },
        "allowed_tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": { "type": "object" }
  }
}
