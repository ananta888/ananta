{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ananta.dev/schemas/contracts/langchain-chain-descriptor.v1.json",
  "title": "LangChainChainDescriptor v1",
  "description": "Deklaratives Descriptor-Format für erlaubte LangChain Chains (LCG-014). Validierbar ohne LangChain-Installation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "purpose", "inputs", "outputs", "model_ref", "policies"],
  "properties": {
    "schema": { "const": "langchain-chain-descriptor.v1" },
    "id": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "default": "1.0" },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean", "default": true },
          "description": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "artifact_first": { "type": "boolean", "default": true }
        }
      }
    },
    "model_ref": { "type": "string", "minLength": 1 },
    "retriever_ref": {
      "type": "string",
      "description": "Must be 'codecompass' or null — no external retriever sources",
      "enum": ["codecompass", null]
    },
    "tools": {
      "type": "array",
      "description": "Whitelist of allowed tool names. Empty = no tools allowed.",
      "items": { "type": "string" }
    },
    "policies": {
      "type": "object",
      "properties": {
        "external_calls_allowed": { "type": "boolean", "default": false },
        "requires_approval": { "type": "boolean", "default": false },
        "artifact_first": { "type": "boolean", "default": true },
        "max_steps": { "type": "integer", "minimum": 1, "default": 12 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "default": 120 }
      }
    },
    "artifact_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "artifact_type"],
        "properties": {
          "name": { "type": "string" },
          "artifact_type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
